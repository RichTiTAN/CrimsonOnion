                                                        <ToggleSwitch Grid.Column="2" x:Name="togAdapterBinding" OnContent="{x:Null}" OffContent="{x:Null}" HorizontalAlignment="Right" VerticalAlignment="Center" MinWidth="40" Margin="0,0,10,0" IsCheckedChanged="togAdapterBinding_IsCheckedChanged"/>
                                                        <PathIcon x:Name="icoAdapterBindingExpander" Grid.Column="3" Data="M7.41 8.59L12 13.17l4.59-4.58L18 10l-6 6-6-6 1.41-1.41z" Width="12" Height="12" Foreground="#8B949E" VerticalAlignment="Center">
                                                            <PathIcon.Transitions>
