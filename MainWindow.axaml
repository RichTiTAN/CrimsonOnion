                                        <StackPanel Spacing="0">
                                            <Border x:Name="panDnsToggle" Background="#101112" BorderBrush="#2D3748" BorderThickness="1" CornerRadius="8" Padding="0">
                                                <Button x:Name="btnDnsToggle" Classes="optBtn" CornerRadius="8" BorderThickness="0" Background="Transparent" Padding="12,8" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Click="btnDnsToggle_Click">
                                                    <Grid ColumnDefinitions="Auto, *, Auto" MinHeight="36">
                                                        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                                                            <PathIcon Data="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 17.93c-3.95-.49-7-3.85-7-7.93 0-.62.08-1.21.21-1.79L9 15v1c0 1.1.9 2 2 2v1.93zm6.9-2.54c-.26-.81-1-1.39-1.9-1.39h-1v-3c0-.55-.45-1-1-1H8v-2h2c.55 0 1-.45 1-1V7h2c1.1 0 2-.9 2-2v-.41c2.93 1.19 5 4.06 5 7.41 0 2.08-.8 3.97-2.1 5.39z" Width="14" Height="14" Foreground="#8B949E"/>
                                                            <StackPanel Orientation="Horizontal" Spacing="3" VerticalAlignment="Center">
                                                                <TextBlock x:Name="lblDnsSettingTitle" Classes="settingTitle" Text="DNS SETTINGS" FontSize="11" FontWeight="SemiBold" LetterSpacing="1" VerticalAlignment="Center" ToolTip.Tip="Resolve DNS through encrypted DNS-over-HTTPS (DoH) instead of plaintext queries. Reduces DNS leaks and censorship. Pick a provider or enter a custom DoH URL; applies in proxy mode (Xray) and VPN mode (sing-box)."/>
                                                            </StackPanel>
                                                        </StackPanel>
                                                        <PathIcon x:Name="icoDnsExpander" Grid.Column="2" Data="M7.41 8.59L12 13.17l4.59-4.58L18 10l-6 6-6-6 1.41-1.41z" Width="12" Height="12" Foreground="#8B949E" VerticalAlignment="Center">
                                                            <PathIcon.Transitions>
                                                                <Transitions>
                                                                    <DoubleTransition Property="RotateTransform.Angle" Duration="0:0:0.2" Easing="CubicEaseOut"/>
                                                                </Transitions>
                                                            </PathIcon.Transitions>
                                                        </PathIcon>
                                                    </Grid>
                                                </Button>
                                            </Border>
                                            <Border x:Name="panDnsSettings" Background="#0A0B0E" BorderBrush="#2D3748" BorderThickness="1,0,1,1" CornerRadius="0,0,8,8" MaxHeight="0" Opacity="0" ClipToBounds="True">
                                                <Border.Transitions>
                                                    <Transitions>
                                                        <DoubleTransition Property="MaxHeight" Duration="0:0:0.3" Easing="CubicEaseOut"/>
                                                        <DoubleTransition Property="Opacity" Duration="0:0:0.3" Easing="CubicEaseOut"/>
                                                    </Transitions>
                                                </Border.Transitions>
                                                <StackPanel Margin="15,9,15,12" Spacing="7">
                                                    <Grid ColumnDefinitions="Auto,*,Auto">
                                                        <TextBlock x:Name="lblUpstreamDoh" Grid.Column="0" Text="UPSTREAM DOH URL" FontSize="10" FontWeight="Bold" Foreground="#A0AEC0" VerticalAlignment="Center"/>
                                                        <ToggleSwitch Grid.Column="2" x:Name="togDnsSettings" OnContent="{x:Null}" OffContent="{x:Null}" HorizontalAlignment="Right" VerticalAlignment="Center" MinWidth="40" Margin="0,0,-5,0" IsCheckedChanged="togDnsSettings_IsCheckedChanged">
                                                            <ToggleSwitch.RenderTransform>
                                                                <ScaleTransform ScaleX="0.78" ScaleY="0.78"/>
                                                            </ToggleSwitch.RenderTransform>
                                                        </ToggleSwitch>
                                                    </Grid>
                                                    <Grid ColumnDefinitions="*,Auto">
                                                        <ComboBox x:Name="cmbDohUrl" Grid.Column="0" IsEditable="True" Background="#1A1C20" Foreground="#68D391" BorderBrush="#2D3748" BorderThickness="1" CornerRadius="4,0,0,4" MinHeight="26" Height="26" FontSize="11" VerticalContentAlignment="Center" HorizontalAlignment="Stretch" Margin="0,0,0,0">
                                                            <ComboBox.Styles>
                                                                <Style Selector="TextBox">
                                                                    <Setter Property="Padding" Value="8,4,8,0" />
                                                                    <Setter Property="VerticalAlignment" Value="Center" />
                                                                    <Setter Property="VerticalContentAlignment" Value="Center" />
                                                                </Style>
                                                            </ComboBox.Styles>
                                                            <ComboBoxItem Content="https://cloudflare-dns.com/dns-query" />
                                                            <ComboBoxItem Content="https://dns.google/dns-query" />
                                                            <ComboBoxItem Content="https://dns.quad9.net/dns-query" />
                                                            <ComboBoxItem Content="https://dns.adguard.com/dns-query" />
                                                            <ComboBoxItem Content="https://doh.opendns.com/dns-query" />
                                                        </ComboBox>
                                                        <Border Grid.Column="1" Background="#0A0C0F" CornerRadius="0,4,4,0" BorderBrush="#2D3748" BorderThickness="0,1,1,1" Width="52" MinHeight="26">
                                                            <Button x:Name="btnDohSave" Click="btnDohSave_Click" Content="SAVE" FontSize="10" FontWeight="Bold" Foreground="#A0AEC0" Background="Transparent" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" VerticalAlignment="Stretch" VerticalContentAlignment="Center" Cursor="Hand" BorderThickness="0" CornerRadius="0,4,4,0" Padding="0">
                                                                <Button.Styles>
                                                                    <Style Selector="Button:pointerover /template/ ContentPresenter">
                                                                        <Setter Property="Background" Value="#2AFFFFFF"/>
                                                                        <Setter Property="TextBlock.Foreground" Value="#68D391"/>
                                                                    </Style>
                                                                </Button.Styles>
                                                            </Button>
                                                        </Border>
                                                    </Grid>
                                                    <Border Background="#2D3748" Height="1" Margin="-15,3,-15,0"/>
                                                    <Grid ColumnDefinitions="Auto,*,Auto" Margin="0,-3,0,0">
                                                        <TextBlock x:Name="lblSysDnsTitle" Grid.Column="0" Text="SYSTEM DNS" FontSize="10" FontWeight="Bold" Foreground="#A0AEC0" VerticalAlignment="Center" ToolTip.Tip="Changes the Windows DNS of your main network adapter when you connect, so Tor bootstrap benefits from it. Restored to original on disconnect or app close."/>
                                                        <ToggleSwitch Grid.Column="2" x:Name="togSysDns" OnContent="{x:Null}" OffContent="{x:Null}" HorizontalAlignment="Right" VerticalAlignment="Center" MinWidth="40" Margin="0,0,-5,0" IsCheckedChanged="togSysDns_IsCheckedChanged">
                                                            <ToggleSwitch.RenderTransform>
                                                                <ScaleTransform ScaleX="0.78" ScaleY="0.78"/>
                                                            </ToggleSwitch.RenderTransform>
