                                                                <StackPanel Grid.Column="0" Spacing="5" Margin="0,0,5,0">
                                                                    <TextBlock x:Name="lblOutboundUsername" Text="USERNAME" FontSize="10" FontWeight="Bold" Foreground="#A0AEC0"/>
                                                                    <TextBox x:Name="txtOutboundUser" MinHeight="26" Height="26" VerticalContentAlignment="Center" Background="#1A1C20" Foreground="#68D391" BorderBrush="#2D3748" BorderThickness="1" FontFamily="Consolas" FontSize="11" CornerRadius="4"/>
                                                                </StackPanel>
                                                                <StackPanel Grid.Column="1" Spacing="5" Margin="5,0,0,0">
                                                                    <TextBlock x:Name="lblOutboundPassword" Text="PASSWORD" FontSize="10" FontWeight="Bold" Foreground="#A0AEC0"/>
                                                                    <TextBox x:Name="txtOutboundPass" MinHeight="26" Height="26" VerticalContentAlignment="Center" Background="#1A1C20" Foreground="#68D391" BorderBrush="#2D3748" BorderThickness="1" FontFamily="Consolas" FontSize="11" CornerRadius="4"/>
                                                                </StackPanel>
                                                            </Grid>
                                                        </StackPanel>
                                                    </Border>

                                                    <Grid ColumnDefinitions="Auto, *">
                                                        <Border Grid.Column="1" Background="#0A0C0F" CornerRadius="3" BorderBrush="#2D3748" BorderThickness="1" HorizontalAlignment="Right" Width="140" Margin="0">
                                                            <Grid ColumnDefinitions="*, 1, *">
                                                                <Button x:Name="btnOutboundSave" Click="btnOutboundSave_Click" Grid.Column="0" Content="SAVE" FontSize="10" FontWeight="Bold" Foreground="#A0AEC0" Background="Transparent" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" VerticalAlignment="Stretch" Cursor="Hand" BorderThickness="0" CornerRadius="3,0,0,3">
                                                                    <Button.Styles>
                                                                        <Style Selector="Button:pointerover /template/ ContentPresenter">
                                                                            <Setter Property="Background" Value="#2AFFFFFF"/>
                                                                        </Style>
                                                                    </Button.Styles>
                                                                </Button>
                                                                <Border Grid.Column="1" Background="#2D3748"/>
                                                                <Button x:Name="btnOutboundCancel" Click="btnOutboundCancel_Click" Grid.Column="2" Content="CANCEL" FontSize="10" FontWeight="Bold" Foreground="#A0AEC0" Background="Transparent" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" VerticalAlignment="Stretch" Cursor="Hand" BorderThickness="0" CornerRadius="0,3,3,0">
                                                                    <Button.Styles>
                                                                        <Style Selector="Button:pointerover /template/ ContentPresenter">
                                                                            <Setter Property="Background" Value="#2AFFFFFF"/>
                                                                        </Style>
                                                                    </Button.Styles>
                                                                </Button>
                                                            </Grid>
                                                        </Border>
                                                    </Grid>
                                                </StackPanel>
                                            </Border>
