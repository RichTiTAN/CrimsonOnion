                                            <Border x:Name="panLanSettings" Background="#0A0B0E" BorderBrush="#2D3748" BorderThickness="1,0,1,1" CornerRadius="0,0,8,8" MaxHeight="0" Opacity="0" ClipToBounds="True">
                                                <Border.Transitions>
                                                    <Transitions>
                                                        <DoubleTransition Property="MaxHeight" Duration="0:0:0.3" Easing="CubicEaseOut"/>
                                                        <DoubleTransition Property="Opacity" Duration="0:0:0.3" Easing="CubicEaseOut"/>
                                                    </Transitions>
                                                </Border.Transitions>
                                                <StackPanel Margin="15,12,15,12" Spacing="2">
                                                    <!-- Authentication toggle row -->
                                                    <Grid ColumnDefinitions="Auto,*,Auto" MinHeight="30">
                                                        <TextBlock x:Name="lblLanAuthTitle" Grid.Column="0" Text="AUTHENTICATION" FontSize="10" FontWeight="Bold" Foreground="#A0AEC0" VerticalAlignment="Center"/>
                                                        <ToggleSwitch x:Name="togLanAuth" Grid.Column="2" OnContent="{x:Null}" OffContent="{x:Null}" HorizontalAlignment="Right" VerticalAlignment="Center" MinWidth="40" Margin="0,0,-5,0" IsCheckedChanged="togLanAuth_IsCheckedChanged">
                                                            <ToggleSwitch.RenderTransform>
                                                                <ScaleTransform ScaleX="0.78" ScaleY="0.78"/>
                                                            </ToggleSwitch.RenderTransform>
                                                        </ToggleSwitch>
                                                    </Grid>
                                                    <!-- Username / Password / Save -->
                                                    <Grid ColumnDefinitions="*,6,*,1,Auto">
                                                        <TextBox x:Name="txtLanUser" Grid.Column="0" Background="#1A1C20" Foreground="#68D391" BorderBrush="#2D3748" BorderThickness="1" CornerRadius="4,0,0,4" MinHeight="26" Height="26" FontSize="11" VerticalContentAlignment="Center" Padding="8,4,8,4" PlaceholderText="Username"/>
                                                        <Grid Grid.Column="2">
                                                            <TextBox x:Name="txtLanPass" Background="#1A1C20" Foreground="#68D391" BorderBrush="#2D3748" BorderThickness="1,1,0,1" CornerRadius="0" MinHeight="26" Height="26" FontSize="11" VerticalContentAlignment="Center" Padding="8,4,30,4" PlaceholderText="Password" PasswordChar="&#x2022;"/>
                                                            <Button x:Name="btnLanPassEye" Click="btnLanPassEye_Click" Background="Transparent" BorderThickness="0" Width="26" Height="24" HorizontalAlignment="Right" Margin="0,0,1,0" Padding="0" Cursor="Hand" VerticalContentAlignment="Center" HorizontalContentAlignment="Center">
                                                                <PathIcon x:Name="icoLanPassEye" Data="M12 4.5C7 4.5 2.73 7.61 1 12c1.73 4.39 6 7.5 11 7.5s9.27-3.11 11-7.5c-1.73-4.39-6-7.5-11-7.5zM12 17c-2.76 0-5-2.24-5-5s2.24-5 5-5 5 2.24 5 5-2.24 5-5 5zm0-8c-1.66 0-3 1.34-3 3s1.34 3 3 3 3-1.34 3-3-1.34-3-3-3z" Width="13" Height="13" Foreground="#718096"/>
                                                                <Button.Styles>
                                                                    <Style Selector="Button:pointerover /template/ ContentPresenter">
                                                                        <Setter Property="Background" Value="#1AFFFFFF"/>
                                                                    </Style>
                                                                </Button.Styles>
                                                            </Button>
                                                        </Grid>
                                                        <Border Grid.Column="3" Background="#2D3748" Width="1"/>
                                                        <Border Grid.Column="4" Background="#0A0C0F" CornerRadius="0,4,4,0" BorderBrush="#2D3748" BorderThickness="0,1,1,1" Width="52" MinHeight="26">
                                                            <Button x:Name="btnLanAuthSave" Click="btnLanAuthSave_Click" Content="SAVE" FontSize="10" FontWeight="Bold" Foreground="#A0AEC0" Background="Transparent" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" VerticalAlignment="Stretch" VerticalContentAlignment="Center" Cursor="Hand" BorderThickness="0" CornerRadius="0,4,4,0" Padding="0">
                                                                <Button.Styles>
                                                                    <Style Selector="Button:pointerover /template/ ContentPresenter">
                                                                        <Setter Property="Background" Value="#2AFFFFFF"/>
                                                                        <Setter Property="TextBlock.Foreground" Value="#68D391"/>
                                                                    </Style>
                                                                </Button.Styles>
                                                            </Button>
                                                        </Border>
                                                    </Grid>
                                                </StackPanel>
                                            </Border>
                                        </StackPanel>
                                    </StackPanel>
                                    
                                    <TextBlock x:Name="lblSectionSystem" Text="SYSTEM" FontSize="11" FontWeight="SemiBold" Foreground="#8B949E" LetterSpacing="1" Margin="5,15,0,0"/>
                                    <StackPanel Spacing="8">
                                        <Border Background="#101112" BorderBrush="#2D3748" BorderThickness="1" CornerRadius="8" Padding="12,8">
                                            <Grid ColumnDefinitions="Auto, *, Auto" MinHeight="36">
                                                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                                                    <PathIcon Data="M11.99 2C6.47 2 2 6.48 2 12s4.47 10 9.99 10C17.52 22 22 17.52 22 12S17.52 2 11.99 2zm6.93 6h-2.95c-.32-1.25-.78-2.45-1.38-3.56 1.84.63 3.37 1.91 4.33 3.56zM12 4.04c.83 1.2 1.48 2.53 1.91 3.96h-3.82c.43-1.43 1.08-2.76 1.91-3.96zM4.26 14C4.09 13.36 4 12.69 4 12s.09-1.36.26-2h3.38c-.08.66-.14 1.32-.14 2s.06 1.34.14 2H4.26zm.82 2h2.95c.32 1.25.78 2.45 1.38 3.56-1.84-.63-3.37-1.9-4.33-3.56zm2.95-8H5.08c.96-1.66 2.49-2.93 4.33-3.56C8.81 5.55 8.35 6.75 8.03 8zM12 19.96c-.83-1.2-1.48-2.53-1.91-3.96h3.82c-.43 1.43-1.08 2.76-1.91 3.96zM14.34 14H9.66c-.09-.66-.16-1.32-.16-2s.07-1.34.16-2h4.68c.09.66.16 1.32.16 2s-.07 1.34-.16 2zm.25 5.56c.6-1.11 1.06-2.31 1.38-3.56h2.95c-.96 1.65-2.49 2.93-4.33 3.56zM16.36 14c.08-.66.14-1.32.14-2s-.06-1.34-.14-2h3.38c.17.64.26 1.31.26 2s-.09 1.36-.26 2h-3.38z" Width="14" Height="14" Foreground="#8B949E"/>
                                                    <TextBlock x:Name="lblLanguageSetting" Classes="settingTitle" Text="LANGUAGE" FontSize="11" FontWeight="SemiBold" LetterSpacing="1" VerticalAlignment="Center" ToolTip.Tip="Change the application language. Reopening the app may be required for all changes to take effect."/>
                                                </StackPanel>
                                                <Button x:Name="btnLanguage" Grid.Column="2" Classes="optBtn" Click="BtnLanguage_Click" Background="#0A0C0F" Foreground="#E2E8F0" BorderBrush="#3A3F44" BorderThickness="1" CornerRadius="4" Width="90" MinHeight="26" Height="26" Padding="8,0" HorizontalAlignment="Right" VerticalAlignment="Center" Cursor="Hand">
                                                    <Grid ColumnDefinitions="*, Auto">
                                                        <TextBlock x:Name="lblCurrentLanguage" Grid.Column="0" Text="ENGLISH" FontSize="11" FontWeight="Bold" VerticalAlignment="Center" HorizontalAlignment="Left"/>
                                                        <PathIcon Grid.Column="1" Data="M7 10l5 5 5-5z" Width="10" Height="10" Foreground="#8B949E" VerticalAlignment="Center" Margin="5,0,0,0" HorizontalAlignment="Right"/>
                                                    </Grid>
                                                </Button>
                                            </Grid>
                                        </Border>
                                        <Border Background="#101112" BorderBrush="#2D3748" BorderThickness="1" CornerRadius="8" Padding="12,8">
                                            <Grid ColumnDefinitions="Auto, *, Auto" MinHeight="36">
                                                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                                                    <PathIcon Data="M20 4H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 14H4V8h16v10zm-2-1h-6v-2h6v2zM7.5 17l-1.41-1.41L8.67 13l-2.59-2.59L7.5 9l4 4-4 4z" Width="14" Height="14" Foreground="#8B949E"/>
                                                    <TextBlock x:Name="lblDebugMode" Classes="settingTitle" Text="DEBUG MODE" FontSize="11" FontWeight="SemiBold" LetterSpacing="1" VerticalAlignment="Center" ToolTip.Tip="Show console windows for Tor, Xray, HAProxy, and sing-box instead of hiding them. Helpful for reading live logs when something fails to connect. Does not change routing or securityÃ¢â‚¬â€only visibility."/>
                                                </StackPanel>
                                                <ToggleSwitch x:Name="btnDebugTog" Grid.Column="2" IsCheckedChanged="SettingTog_CheckedChanged" OnContent="{x:Null}" OffContent="{x:Null}" VerticalAlignment="Center"/>
                                            </Grid>
                                        </Border>
                                        <Grid ColumnDefinitions="*, *">
                                            <Border Grid.Column="0" Background="#101112" BorderBrush="#2D3748" BorderThickness="1" CornerRadius="8" Padding="12,8" Margin="0,0,5,0">
                                                <Grid ColumnDefinitions="Auto, *, Auto" MinHeight="36">
                                                    <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                                                        <PathIcon Data="M21 2H3c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h7v2H8v2h8v-2h-2v-2h7c1.1 0 2-.9 2-2V4c0-1.1-.9-2-2-2zm0 14H3V4h18v12z" Width="14" Height="14" Foreground="#8B949E"/>
                                                        <TextBlock x:Name="lblDesktopShortcut" Text="DESKTOP SHORTCUT" FontSize="11" FontWeight="SemiBold" Foreground="#8B949E" LetterSpacing="1" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                    <Button Grid.Column="2" x:Name="btnDesktopShortcut" Content="CREATE" Classes="optBtn" FontSize="10" Padding="8,4" Background="#1AFFFFFF" Click="Shortcut_Click"/>
                                                </Grid>
                                            </Border>
                                            <Border Grid.Column="1" Background="#101112" BorderBrush="#2D3748" BorderThickness="1" CornerRadius="8" Padding="12,8" Margin="5,0,0,0">
                                                <Grid ColumnDefinitions="Auto, *, Auto" MinHeight="36">
                                                    <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                                                        <PathIcon Data="M3 13h8V3H3v10zm0 8h8v-6H3v6zm10 0h8V11h-8v10zm0-18v6h8V3h-8z" Width="14" Height="14" Foreground="#8B949E"/>
                                                        <TextBlock x:Name="lblStartMenuShortcut" Text="START MENU SHORTCUT" FontSize="11" FontWeight="SemiBold" Foreground="#8B949E" LetterSpacing="1" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                    <Button Grid.Column="2" x:Name="btnStartMenuShortcut" Content="CREATE" Classes="optBtn" FontSize="10" Padding="8,4" Background="#1AFFFFFF" Click="Shortcut_Click"/>
                                                </Grid>
                                            </Border>
                                        </Grid>
                                    </StackPanel>
                                </StackPanel>
                            </ScrollViewer>
                            
                            <Button x:Name="btnSettingsClose" Background="Transparent" BorderThickness="0" Cursor="Hand" Click="btnSettingsClose_Click" HorizontalAlignment="Right" VerticalAlignment="Top" Padding="5" Margin="0,8,8,0">
                                <Button.Styles>
                                    <Style Selector="Button:pointerover /template/ ContentPresenter">
                                        <Setter Property="Background" Value="Transparent"/>
                                    </Style>
                                    <Style Selector="Button:pointerover PathIcon">
                                        <Setter Property="Foreground" Value="#E2E8F0"/>
                                    </Style>
                                </Button.Styles>
                                <PathIcon Data="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z" Width="10" Height="10" Foreground="#8B949E"/>
                            </Button>
                        </Grid>
                    </Border>

                    <Border x:Name="panSplitOverlay" Classes="popupContent" Grid.Column="1" Background="#F2101116" BorderBrush="#2D3748" BorderThickness="1" CornerRadius="12" Margin="-5,10,25,15" ZIndex="400" IsVisible="False" Padding="0" VerticalAlignment="Top" MaxHeight="460" BoxShadow="0 0 50 1000 #B3000000">
                        <Border.Styles>
                            <Style Selector="TextBox:readonly /template/ Border#PART_BorderElement">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="BorderThickness" Value="0"/>
                            </Style>
                            <Style Selector="TextBox:disabled /template/ Border#PART_BorderElement">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="BorderThickness" Value="0"/>
                            </Style>
                        </Border.Styles>
                        <Grid>
                            <ScrollViewer>
                                <StackPanel Margin="20,20,20,20" Spacing="20">
                                    
                                    <Border Background="#1A1B1E" BorderBrush="#2D3748" BorderThickness="1" CornerRadius="8" Padding="15,10">
                                        <StackPanel Spacing="0">
                                            
                                            <Grid ColumnDefinitions="*, Auto">
                                                <TextBlock x:Name="lblSplitTunnelingHeader" Grid.Column="0" Text="SPLIT TUNNELING" FontSize="11" FontWeight="SemiBold" Foreground="#8B949E" LetterSpacing="1" VerticalAlignment="Center"/>
                                                
                                                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                                                    <Button x:Name="btnSplitDisabled" Classes="optBtn activeOpt" Click="SplitTunnel_Click" ToolTip.Tip="Split tunneling is disabled."><TextBlock Text="DISABLED" FontSize="11" FontWeight="SemiBold"/></Button>
                                                    <Button x:Name="btnSplitExclusive" Classes="optBtn" Click="SplitTunnel_Click" ToolTip.Tip="Only bypass the proxy for the apps, domains, IPs and ports listed here."><TextBlock Text="EXCLUSIVE" FontSize="11" FontWeight="SemiBold"/></Button>
                                                    <Button x:Name="btnSplitInclusive" Classes="optBtn" Click="SplitTunnel_Click" ToolTip.Tip="Only route the apps, domains, IPs and ports listed here through the proxy."><TextBlock Text="INCLUSIVE" FontSize="11" FontWeight="SemiBold"/></Button>
                                                </StackPanel>
                                            </Grid>
                                            
                                            <Border x:Name="panSplitConfig" MaxHeight="0" Opacity="0" ClipToBounds="True">
                                                <Border.Transitions>
                                                    <Transitions>
                                                        <DoubleTransition Property="MaxHeight" Duration="0:0:0.3" Easing="CubicEaseOut"/>
                                                        <DoubleTransition Property="Opacity" Duration="0:0:0.3" Easing="CubicEaseOut"/>
                                                    </Transitions>
                                                </Border.Transitions>
                                                <StackPanel Spacing="13" Margin="0,13,0,0">
                                                    <TextBlock x:Name="lblSplitExplanation" FontSize="11.5" Foreground="#A0AEC0" TextWrapping="Wrap" LineHeight="17" Margin="2,0,2,2" />
                                                    
                                                    <Grid>
<StackPanel x:Name="panSplitDomains" Spacing="0">
                                                        <Border x:Name="panDomainsToggle" Background="#101112" BorderBrush="#2D3748" BorderThickness="1" CornerRadius="4" Padding="0">
                                                            <Grid ColumnDefinitions="*, Auto">
                                                                <Border Padding="15,5" VerticalAlignment="Center">
                                                                    <TextBlock x:Name="lblDomainsAndIps" Text="DOMAINS, IPs &amp; PORTS" FontSize="11" FontWeight="Bold" Foreground="#8B949E" LetterSpacing="1" />
                                                                </Border>
                                                                <Button Grid.Column="1" x:Name="btnToggleDomains" Classes="optBtn" CornerRadius="0,3,3,0" BorderThickness="1,0,0,0" BorderBrush="#2D3748" Padding="15,5" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Click="SplitToggle_Click" Content="ADD" FontSize="11" FontWeight="SemiBold" Foreground="#8B949E" VerticalContentAlignment="Center" HorizontalContentAlignment="Center">
                                                                </Button>
                                                            </Grid>
                                                        </Border>
                                                        <Border x:Name="panDomainsEdit" Background="#0A0B0E" BorderBrush="#2D3748" BorderThickness="1,0,1,1" CornerRadius="0,0,4,4" Height="0" ClipToBounds="True">
                                                            <Border.Transitions>
                                                                <Transitions>
                                                                    <DoubleTransition Property="Height" Duration="0:0:0.2" Easing="CubicEaseOut"/>
                                                                </Transitions>
                                                            </Border.Transitions>
                                                            <StackPanel Margin="10,0,10,0">
                                                                <Border Margin="0,3,0,0">
                                                                    <TextBox x:Name="txtSplitDomains" Height="20" LineHeight="17" Background="Transparent" BorderThickness="0" PlaceholderText="example.com, 1.2.3.4, 443" FontSize="11" Foreground="#E2E8F0" AcceptsReturn="True" TextWrapping="Wrap"/>
                                                                </Border>
                                                                <Border Background="#101112" BorderBrush="#2D3748" BorderThickness="1" CornerRadius="6" HorizontalAlignment="Right" Margin="0,10,0,0" Width="140">
                                                                    <Grid ColumnDefinitions="*, 1, *">
                                                                        <Button Grid.Column="0" x:Name="btnSaveDomains" Content="SAVE" FontSize="10" FontWeight="Bold" Background="Transparent" Foreground="#E2E8F0" Padding="0,4" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Click="SplitSave_Click"/>
                                                                        <Border Grid.Column="1" Background="#2D3748" Width="1"/>
                                                                        <Button Grid.Column="2" x:Name="btnCancelDomains" Content="CANCEL" FontSize="10" FontWeight="Bold" Background="Transparent" Foreground="#8B949E" Padding="0,4" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Click="SplitCancel_Click"/>
                                                                    </Grid>
                                                                </Border>
                                                            </StackPanel>
                                                        </Border>
</StackPanel>
</Grid>

                                                    <Grid>
<StackPanel x:Name="panSplitApps" Spacing="0">
                                                        <Border x:Name="panAppsToggle" Background="#101112" BorderBrush="#2D3748" BorderThickness="1" CornerRadius="4" Padding="0">
                                                            <Grid ColumnDefinitions="*, Auto, Auto">
                                                                <Border Grid.Column="0" Padding="15,5" VerticalAlignment="Center">
                                                                    <TextBlock x:Name="lblApplications" Text="APPLICATIONS" FontSize="11" FontWeight="Bold" Foreground="#8B949E" LetterSpacing="1" />
                                                                </Border>
                                                                <Button Grid.Column="1" Classes="optBtn" CornerRadius="0" BorderThickness="1,0,0,0" BorderBrush="#2D3748" Padding="15,5" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Click="BrowseApp_Click" Content="BROWSE" FontSize="11" FontWeight="SemiBold" Foreground="#8B949E" VerticalContentAlignment="Center" HorizontalContentAlignment="Center">
                                                                </Button>
                                                                <Button Grid.Column="2" x:Name="btnToggleApps" Classes="optBtn" CornerRadius="0,3,3,0" BorderThickness="1,0,0,0" BorderBrush="#2D3748" Padding="15,5" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Click="SplitToggle_Click" Content="ADD" FontSize="11" FontWeight="SemiBold" Foreground="#8B949E" VerticalContentAlignment="Center" HorizontalContentAlignment="Center">
                                                                </Button>
                                                            </Grid>
                                                        </Border>
                                                        <Border x:Name="panAppsEdit" Background="#0A0B0E" BorderBrush="#2D3748" BorderThickness="1,0,1,1" CornerRadius="0,0,4,4" Height="0" ClipToBounds="True">
                                                            <Border.Transitions>
                                                                <Transitions>
                                                                    <DoubleTransition Property="Height" Duration="0:0:0.2" Easing="CubicEaseOut"/>
                                                                </Transitions>
                                                            </Border.Transitions>
                                                            <StackPanel Margin="10,0,10,0">
                                                                <Border Margin="0,3,0,0">
                                                                    <TextBox x:Name="txtSplitApps" Height="20" LineHeight="17" Background="Transparent" BorderThickness="0" PlaceholderText="app.exe, game.exe" FontSize="11" Foreground="#E2E8F0" AcceptsReturn="True" TextWrapping="Wrap"/>
                                                                </Border>
                                                                <Grid Margin="0,10,0,0">
                                                                    <TextBlock x:Name="lblSplitAppsWarning" Text="Warning: Case sensitive" FontSize="10" Foreground="#E53E3E" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="2,0,0,0"/>
                                                                    <Border Background="#101112" BorderBrush="#2D3748" BorderThickness="1" CornerRadius="6" HorizontalAlignment="Right" Width="140">
                                                                        <Grid ColumnDefinitions="*, 1, *">
                                                                            <Button Grid.Column="0" x:Name="btnSaveApps" Content="SAVE" FontSize="10" FontWeight="Bold" Background="Transparent" Foreground="#E2E8F0" Padding="0,4" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Click="SplitSave_Click"/>
                                                                            <Border Grid.Column="1" Background="#2D3748" Width="1"/>
                                                                            <Button Grid.Column="2" x:Name="btnCancelApps" Content="CANCEL" FontSize="10" FontWeight="Bold" Background="Transparent" Foreground="#8B949E" Padding="0,4" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Click="SplitCancel_Click"/>
                                                                        </Grid>
                                                                    </Border>
                                                                </Grid>
                                                            </StackPanel>
                                                        </Border>
</StackPanel>
</Grid>

                                                    <StackPanel x:Name="panSplitBlock" Spacing="0">
                                                        <Border x:Name="panBlockToggle" Background="#101112" BorderBrush="#2D3748" BorderThickness="1" CornerRadius="4" Padding="0">
                                                            <Grid ColumnDefinitions="*, Auto">
                                                                <Border Padding="15,5" VerticalAlignment="Center">
                                                                    <TextBlock x:Name="lblBlockedDomainsIps" Text="BLOCKED DOMAINS, IPs &amp; PORTS" FontSize="11" FontWeight="Bold" Foreground="#8B949E" LetterSpacing="1" />
                                                                </Border>
                                                                <Button Grid.Column="1" x:Name="btnToggleBlock" Classes="optBtn" CornerRadius="0,3,3,0" BorderThickness="1,0,0,0" BorderBrush="#2D3748" Padding="15,5" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Click="SplitToggle_Click" Content="ADD" FontSize="11" FontWeight="SemiBold" Foreground="#8B949E" VerticalContentAlignment="Center" HorizontalContentAlignment="Center">
                                                                </Button>
                                                            </Grid>
                                                        </Border>
                                                        <Border x:Name="panBlockEdit" Background="#0A0B0E" BorderBrush="#2D3748" BorderThickness="1,0,1,1" CornerRadius="0,0,4,4" Height="0" ClipToBounds="True">
                                                            <Border.Transitions>
                                                                <Transitions>
                                                                    <DoubleTransition Property="Height" Duration="0:0:0.2" Easing="CubicEaseOut"/>
                                                                </Transitions>
                                                            </Border.Transitions>
                                                            <StackPanel Margin="10,0,10,0">
                                                                <Border Margin="0,3,0,0">
                                                                    <TextBox x:Name="txtSplitBlock" Height="20" LineHeight="17" Background="Transparent" BorderThickness="0" PlaceholderText="malicious.com, 5.6.7.8, 443" FontSize="11" Foreground="#E2E8F0" AcceptsReturn="True" TextWrapping="Wrap"/>
                                                                </Border>
                                                                <Border Background="#101112" BorderBrush="#2D3748" BorderThickness="1" CornerRadius="6" HorizontalAlignment="Right" Margin="0,10,0,0" Width="140">
                                                                    <Grid ColumnDefinitions="*, 1, *">
                                                                        <Button Grid.Column="0" x:Name="btnSaveBlock" Content="SAVE" FontSize="10" FontWeight="Bold" Background="Transparent" Foreground="#E2E8F0" Padding="0,4" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Click="SplitSave_Click"/>
                                                                        <Border Grid.Column="1" Background="#2D3748" Width="1"/>
                                                                        <Button Grid.Column="2" x:Name="btnCancelBlock" Content="CANCEL" FontSize="10" FontWeight="Bold" Background="Transparent" Foreground="#8B949E" Padding="0,4" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Click="SplitCancel_Click"/>
                                                                    </Grid>
                                                                </Border>
                                                            </StackPanel>
                                                        </Border>
                                                    </StackPanel>
                                                    
                                                </StackPanel>
                                            </Border>
                                            
                                        </StackPanel>
                                    </Border>

                                    <Border Background="#1A1B1E" BorderBrush="#2D3748" BorderThickness="1" CornerRadius="8" Padding="15,7" Margin="0,-5,0,0">
                                        <Grid ColumnDefinitions="*, Auto">
                                            <StackPanel Grid.Column="0" Spacing="2" VerticalAlignment="Center">
                                                <TextBlock x:Name="lblDirectUdpHeader" Classes="settingTitle" Text="DIRECT UDP" FontSize="11" FontWeight="SemiBold" LetterSpacing="1" HorizontalAlignment="Left" TextAlignment="Left" />
                                                <TextBlock x:Name="lblDirectUdpDesc" Text="This option can help with video games, discord voice or other udp dependant platforms." FontSize="10" Foreground="#A0AEC0" TextWrapping="Wrap" HorizontalAlignment="Left" TextAlignment="Left" />
                                            </StackPanel>
                                            <ToggleSwitch Grid.Column="1" x:Name="togDirectUDP" IsCheckedChanged="togDirectUDP_IsCheckedChanged" Theme="{DynamicResource FluentToggleSwitchTheme}" OnContent="{x:Null}" OffContent="{x:Null}" HorizontalAlignment="Right" VerticalAlignment="Center" MinWidth="40" Margin="0,0,-5,0" />
                                        </Grid>
                                    </Border>
                                    
                                </StackPanel>
                            </ScrollViewer>
                            
                            <Button Background="Transparent" BorderThickness="0" Cursor="Hand" Click="CloseOverlay_Click" HorizontalAlignment="Right" VerticalAlignment="Top" Padding="5" Margin="0,4,4,0">
                                <Button.Styles>
                                    <Style Selector="Button:pointerover /template/ ContentPresenter">
                                        <Setter Property="Background" Value="Transparent"/>
                                    </Style>
                                    <Style Selector="Button:pointerover PathIcon">
                                        <Setter Property="Foreground" Value="#E2E8F0"/>
                                    </Style>
                                </Button.Styles>
                                <PathIcon Data="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z" Width="10" Height="10" Foreground="#8B949E"/>
                            </Button>
                          </Grid>
                      </Border>
                      
                      <Border x:Name="panAboutOverlay" Classes="popupContent" Grid.Column="1" Background="#F2101116" BorderBrush="#2D3748" BorderThickness="1" CornerRadius="12" Margin="-5,10,25,15" ZIndex="400" IsVisible="False" Padding="0" VerticalAlignment="Top" MaxHeight="460" BoxShadow="0 0 50 1000 #B3000000">
                          <Grid>
                              <ScrollViewer>
                                  <StackPanel Margin="20,20,20,20" Spacing="20">
                                      
                                      <StackPanel Orientation="Horizontal" Spacing="15" VerticalAlignment="Center">
                                          <Image Source="avares://CrimsonOnion/Assets/icon.ico" Width="40" Height="40" RenderOptions.BitmapInterpolationMode="HighQuality"/>
                                          <StackPanel VerticalAlignment="Center">
                                              <TextBlock Text="CrimsonOnion" FontSize="20" FontWeight="Bold" Foreground="#E2E8F0"/>
                                              <TextBlock x:Name="lblAboutCreator" Text="Creator: @RichTitan" FontSize="12" FontWeight="SemiBold" Foreground="#8B949E" Margin="0,2,0,0"/>
                                              <TextBlock x:Name="lblAboutLicense" Text="License: GPL-3.0 license" FontSize="11" FontWeight="Normal" Foreground="#A0AEC0" Margin="0,1,0,0"/>
                                          </StackPanel>
                                      </StackPanel>

                                      <Grid ColumnDefinitions="*,10,*">
                                          <Button Grid.Column="0" Click="BtnGithub_Click" Classes="optBtn" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Background="#101112" BorderBrush="#2D3748" BorderThickness="1" Foreground="#8B949E" FontWeight="SemiBold">
                                              <StackPanel Orientation="Horizontal" Spacing="8">
                                                  <PathIcon Data="M12 2C6.477 2 2 6.477 2 12c0 4.42 2.865 8.166 6.839 9.489.5.092.682-.217.682-.482 0-.237-.009-.866-.013-1.699-2.782.603-3.369-1.34-3.369-1.34-.454-1.156-1.11-1.462-1.11-1.462-.908-.62.069-.608.069-.608 1.003.07 1.531 1.03 1.531 1.03.892 1.529 2.341 1.087 2.91.831.092-.646.35-1.086.636-1.336-2.22-.253-4.555-1.11-4.555-4.943 0-1.091.39-1.984 1.029-2.683-.103-.253-.446-1.27.098-2.647 0 0 .84-.269 2.75 1.025A9.578 9.578 0 0112 6.836c.85.004 1.705.114 2.504.336 1.909-1.294 2.747-1.025 2.747-1.025.546 1.379.203 2.394.1 2.647.64.699 1.028 1.592 1.028 2.683 0 3.842-2.339 4.687-4.566 4.935.359.309.678.919.678 1.852 0 1.336-.012 2.415-.012 2.743 0 .267.18.578.688.48C19.138 20.161 22 16.418 22 12c0-5.523-4.477-10-10-10z" Width="14" Height="14" Foreground="#8B949E"/>
                                                  <TextBlock Text="GitHub"/>
                                              </StackPanel>
                                          </Button>
                                          <Button Grid.Column="2" Click="BtnTelegram_Click" Classes="optBtn" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Background="#101112" BorderBrush="#2D3748" BorderThickness="1" Foreground="#8B949E" FontWeight="SemiBold">
                                              <StackPanel Orientation="Horizontal" Spacing="8">
                                                  <PathIcon Data="M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0a12 12 0 0 0-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 0 1 .171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.48.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.892-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z" Width="14" Height="14" Foreground="#8B949E"/>
                                                  <TextBlock Text="Telegram"/>
                                              </StackPanel>
                                          </Button>
                                      </Grid>
                                      
                                      <Border Background="#1A1B1E" BorderBrush="#2D3748" BorderThickness="1" CornerRadius="8" Padding="15,10">
                                          <Grid ColumnDefinitions="Auto, *, Auto">
                                              <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                                  <PathIcon Data="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-6h2v6zm0-8h-2V7h2v2z" Width="14" Height="14" Foreground="#8B949E"/>
                                                  <TextBlock x:Name="lblAboutVersion" Text="VERSION" FontSize="11" FontWeight="SemiBold" Foreground="#8B949E" LetterSpacing="1" VerticalAlignment="Center"/>
                                              </StackPanel>
                                              <Button x:Name="btnCheckUpdate" Grid.Column="1" Content="CHECK FOR UPDATES" Click="BtnCheckUpdate_Click" FontSize="11" FontWeight="Bold" Background="Transparent" Foreground="#68D391" Padding="5" Cursor="Hand" BorderThickness="0" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,10,0"/>
                                              <TextBlock x:Name="lblVersion" Grid.Column="2" Text="2.0.0" FontSize="14" FontWeight="Bold" Foreground="#E2E8F0" VerticalAlignment="Center"/>
                                          </Grid>
                                      </Border>
                                      
                                      <Border Background="#1A1B1E" BorderBrush="#2D3748" BorderThickness="1" CornerRadius="8" Padding="15,10">
                                          <StackPanel Spacing="15">
                                              <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                                  <PathIcon Data="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z" Width="14" Height="14" Foreground="#8B949E"/>
                                                  <TextBlock x:Name="lblDonations" Text="DONATIONS" FontSize="11" FontWeight="SemiBold" Foreground="#8B949E" LetterSpacing="1" VerticalAlignment="Center"/>
                                                  <TextBlock x:Name="lblDonationsDesc" Text="if u want to support me or the project you can do so by sending your desired amount to one of these wallet addresses," FontSize="9" FontWeight="Normal" Foreground="#A0AEC0" VerticalAlignment="Center" TextWrapping="Wrap" MaxWidth="190" Margin="5,0,0,0"/>
                                              </StackPanel>
                                              
                                              <StackPanel Spacing="8">
                                                  <StackPanel Spacing="2">
                                                      <TextBlock Text="USDT (BEP20)" FontSize="10" FontWeight="SemiBold" Foreground="#8B949E"/>
                                                      <Button Click="BtnCopyAddress_Click" Content="0xFc1d71C22DC2604f6C13Ca540ed842535cbE6d75" FontSize="10" FontWeight="Normal" Foreground="#E2E8F0" Background="Transparent" BorderThickness="0" Padding="0" Cursor="Hand" HorizontalAlignment="Left"/>
                                                  </StackPanel>
                                                  <StackPanel Spacing="2">
                                                      <TextBlock Text="USDT (TRC20)" FontSize="10" FontWeight="SemiBold" Foreground="#8B949E"/>
                                                      <Button Click="BtnCopyAddress_Click" Content="TNMaNGDMG7BzbjkXeiguFWzDHZ4hCUU9R8" FontSize="10" FontWeight="Normal" Foreground="#E2E8F0" Background="Transparent" BorderThickness="0" Padding="0" Cursor="Hand" HorizontalAlignment="Left"/>
                                                  </StackPanel>
                                                  <StackPanel Spacing="2">
                                                      <TextBlock Text="BITCOIN" FontSize="10" FontWeight="SemiBold" Foreground="#8B949E"/>
                                                      <Button Click="BtnCopyAddress_Click" Content="bc1quzdzuhrfse520r0wkqgkvsl7nv354r8sj5u9f9" FontSize="10" FontWeight="Normal" Foreground="#E2E8F0" Background="Transparent" BorderThickness="0" Padding="0" Cursor="Hand" HorizontalAlignment="Left"/>
                                                  </StackPanel>
                                              </StackPanel>
                                          </StackPanel>
                                      </Border>
                                      
                                  </StackPanel>
                              </ScrollViewer>

                              <Button Background="Transparent" BorderThickness="0" Cursor="Hand" Click="CloseOverlay_Click" HorizontalAlignment="Right" VerticalAlignment="Top" Padding="5" Margin="0,8,8,0">
                                  <Button.Styles>
                                      <Style Selector="Button:pointerover /template/ ContentPresenter">
                                          <Setter Property="Background" Value="Transparent"/>
                                      </Style>
                                      <Style Selector="Button:pointerover PathIcon">
                                          <Setter Property="Foreground" Value="#E2E8F0"/>
                                      </Style>
                                  </Button.Styles>
                                  <PathIcon Data="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z" Width="10" Height="10" Foreground="#8B949E"/>
                              </Button>
                          </Grid>
                      </Border>
  
                    <Border x:Name="LightDismissOverlay" Grid.ColumnSpan="2" Background="#01000000" IsVisible="False" PointerPressed="LightDismissOverlay_PointerPressed" ZIndex="200"/>

                    <Popup x:Name="LanguagePopup" IsLightDismissEnabled="False">
                        <Border Classes="popupContent" Background="#E6101116" BorderBrush="#2D3748" BorderThickness="1" CornerRadius="4" Width="90" Padding="2">
                            <StackPanel>
                                <Button Classes="countryControl" Tag="ENGLISH" Click="LanguageOption_Click" Background="Transparent" BorderThickness="0" HorizontalAlignment="Stretch" Padding="8,6" Cursor="Hand" CornerRadius="4">
                                    <TextBlock Text="ENGLISH" VerticalAlignment="Center" Foreground="#E2E8F0" FontSize="11" FontWeight="SemiBold" HorizontalAlignment="Left"/>
                                </Button>
                                <Button Classes="countryControl" Tag="PERSIAN" Click="LanguageOption_Click" Background="Transparent" BorderThickness="0" HorizontalAlignment="Stretch" Padding="8,6" Cursor="Hand" CornerRadius="4">
                                    <TextBlock Text="PERSIAN" VerticalAlignment="Center" Foreground="#E2E8F0" FontSize="11" FontWeight="SemiBold" HorizontalAlignment="Left"/>
                                </Button>
                            </StackPanel>
                        </Border>
                    </Popup>

                    <Popup x:Name="CountriesPopup" IsLightDismissEnabled="False">
                        <Border Classes="popupContent" Background="#E6101116" BorderBrush="#2D3748" BorderThickness="1" CornerRadius="12" Width="260" MaxHeight="425" Padding="5">
                        <ScrollViewer>
                            <StackPanel>
                                    
                                    <Button Classes="countryControl" Tag="Optimized" Click="RoutingOption_Click" Background="Transparent" BorderThickness="0" HorizontalAlignment="Stretch" Padding="15,10" Cursor="Hand" CornerRadius="8" Margin="0,0,5,0">
                                        <StackPanel Orientation="Horizontal" Spacing="15">
                                            <Border Width="24" Height="16">
                                                <PathIcon Data="M7 2v11h3v9l7-12h-4l4-8z" Width="14" Height="14" Foreground="#E2E8F0" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <TextBlock x:Name="lblCountriesOptimized" Text="OPTIMIZED" VerticalAlignment="Center" Foreground="#E2E8F0" FontSize="14" FontWeight="SemiBold"/>
                                        </StackPanel>
                                    </Button>

                                    <Button Classes="countryControl" Tag="Expert" Click="RoutingOption_Click" Background="Transparent" BorderThickness="0" HorizontalAlignment="Stretch" Padding="15,10" Cursor="Hand" CornerRadius="8" Margin="0,0,5,0">
                                        <StackPanel Orientation="Horizontal" Spacing="15">
                                            <Border Width="24" Height="16">
                                                <PathIcon Data="M9.4 16.6L4.8 12l4.6-4.6L8 6l-6 6 6 6 1.4-1.4zm5.2 0l4.6-4.6-4.6-4.6L16 6l6 6-6 6-1.4-1.4z" Width="16" Height="16" Foreground="#E2E8F0" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <TextBlock x:Name="lblCountriesExpert" Text="EXPERT" VerticalAlignment="Center" Foreground="#E2E8F0" FontSize="14" FontWeight="SemiBold"/>
                                        </StackPanel>
                                    </Button>

                                    <Border Height="1" Background="#2D3748" Margin="15,5,20,5" />

                                    <ItemsControl ItemsSource="{Binding Countries}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="local:CountryItem">
                                                <Button Classes="countryControl" Tag="{Binding Tag}" Click="RoutingOption_Click" Background="Transparent" BorderThickness="0" HorizontalAlignment="Stretch" Padding="15,10" Cursor="Hand" CornerRadius="8" Margin="0,0,5,0">
                                                    <StackPanel Orientation="Horizontal" Spacing="15">
                                                        <Image Source="{Binding Flag}" Width="24" Height="16" RenderOptions.BitmapInterpolationMode="HighQuality"/>
                                                        <TextBlock Text="{Binding Name}" VerticalAlignment="Center" Foreground="#E2E8F0" FontSize="14" FontWeight="SemiBold"/>
                                                    </StackPanel>
                                                </Button>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </ScrollViewer>
                        </Border>
                    </Popup>
                    
                </Grid>

                <Border x:Name="ToastBorder"
                        Grid.Row="1"
                        Grid.ColumnSpan="2"
                        IsVisible="False"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Top"
                        Margin="0,15,0,0"
                        ZIndex="1000"
                        Background="#E6101116"
                        BorderBrush="#2D3748"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="18,12,18,12"
                        IsHitTestVisible="False">
                    <Border.Transitions>
                        <Transitions>
                            <DoubleTransition Property="Opacity" Duration="0:0:0.2" Easing="CubicEaseOut"/>
                        </Transitions>
                    </Border.Transitions>
                    <TextBlock x:Name="ToastText"
                               Text=""
                               FontSize="12"
                               FontWeight="Bold"
                               LetterSpacing="1"
                               TextWrapping="Wrap"
                               TextAlignment="Center"
                               MaxWidth="350"
                               HorizontalAlignment="Center"/>
                </Border>

            </Grid>


        </Grid>
    </Border>
</Window>


































