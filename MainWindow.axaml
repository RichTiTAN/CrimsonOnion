                                                            <TextBox x:Name="txtOutboundAddr" MinHeight="26" Height="26" VerticalContentAlignment="Center" Background="#1A1C20" Foreground="#68D391" BorderBrush="#2D3748" BorderThickness="1" FontFamily="Consolas" FontSize="11" CornerRadius="4"/>
                                                        </StackPanel>
                                                        <StackPanel Grid.Column="2" Spacing="5">
                                                            <TextBlock x:Name="lblOutboundPort" Text="PORT" FontSize="10" FontWeight="Bold" Foreground="#A0AEC0"/>
                                                            <TextBox x:Name="txtOutboundPort" Width="80" MinHeight="26" Height="26" VerticalContentAlignment="Center" Background="#1A1C20" Foreground="#68D391" BorderBrush="#2D3748" BorderThickness="1" FontFamily="Consolas" FontSize="11" CornerRadius="4"/>
                                                        </StackPanel>
                                                    </Grid>
                                                    
                                                    <Grid ColumnDefinitions="Auto, *">
                                                        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
