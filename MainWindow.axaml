<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CrimsonOnion"
        mc:Ignorable="d" d:DesignWidth="780" d:DesignHeight="780"
        x:Class="CrimsonOnion.MainWindow"
        x:DataType="local:MainWindow"
        Title="CrimsonOnion" Width="780" SizeToContent="Height"
        Icon="avares://CrimsonOnion/Assets/icon.ico"
        WindowDecorations="None" WindowStartupLocation="CenterScreen"
        Background="Transparent" TransparencyLevelHint="Transparent" 
        Foreground="#E2E8F0" FontFamily="Segoe UI" ToolTip.ShowDelay="1500" ToolTip.BetweenShowDelay="0">
        
    <Window.Resources>
        <LinearGradientBrush x:Key="ThemeCrimsonBrush" StartPoint="0%,0%" EndPoint="100%,100%">
            <GradientStop Color="#4A0811" Offset="0"/>
            <GradientStop Color="#B82E42" Offset="0.5"/>
            <GradientStop Color="#FF6B83" Offset="1"/>
        </LinearGradientBrush>
        
        <LinearGradientBrush x:Key="ThemeBlueBrush" StartPoint="0%,0%" EndPoint="100%,100%">
            <GradientStop Color="#1A365D" Offset="0"/>
            <GradientStop Color="#3182CE" Offset="0.5"/>
            <GradientStop Color="#90CDF4" Offset="1"/>
        </LinearGradientBrush>
        
        <LinearGradientBrush x:Key="ThemePurpleBrush" StartPoint="0%,0%" EndPoint="100%,100%">
            <GradientStop Color="#44337A" Offset="0"/>
            <GradientStop Color="#805AD5" Offset="0.5"/>
            <GradientStop Color="#D6BCFA" Offset="1"/>
        </LinearGradientBrush>
        
        <LinearGradientBrush x:Key="ThemeGreenBrush" StartPoint="0%,0%" EndPoint="100%,100%">
            <GradientStop Color="#1C4532" Offset="0"/>
            <GradientStop Color="#38A169" Offset="0.5"/>
            <GradientStop Color="#9AE6B4" Offset="1"/>
        </LinearGradientBrush>
        
        <LinearGradientBrush x:Key="ThemePinkBrush" StartPoint="0%,0%" EndPoint="100%,100%">
            <GradientStop Color="#702459" Offset="0"/>
            <GradientStop Color="#D53F8C" Offset="0.5"/>
            <GradientStop Color="#FBB6CE" Offset="1"/>
        </LinearGradientBrush>
        
        <LinearGradientBrush x:Key="ThemeYellowBrush" StartPoint="0%,0%" EndPoint="100%,100%">
            <GradientStop Color="#744210" Offset="0"/>
            <GradientStop Color="#D69E2E" Offset="0.5"/>
            <GradientStop Color="#FEFCBF" Offset="1"/>
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="ThemeAllBrush" StartPoint="0%,0%" EndPoint="100%,100%">
            <GradientStop Color="#FF6B83" Offset="0"/>
            <GradientStop Color="#805AD5" Offset="0.5"/>
            <GradientStop Color="#3182CE" Offset="1"/>
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="ThemeCurrentBrush" StartPoint="0%,0%" EndPoint="100%,100%">
            <GradientStop Color="#4A0811" Offset="0"/>
            <GradientStop Color="#E53E3E" Offset="0.5"/>
            <GradientStop Color="#FEB2B2" Offset="1"/>
        </LinearGradientBrush>
    </Window.Resources>

    <Window.Styles>
        <Style Selector="Button.ThemeColorButton:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="Transparent"/>
        </Style>
                <Style Selector="Rectangle.rectGradient">
            <Setter Property="RenderTransformOrigin" Value="50%,50%"/>
            <Setter Property="Opacity" Value="0"/>
            <Setter Property="Transitions">
                <Transitions>
                    <DoubleTransition Property="Opacity" Duration="0:0:0.4" Easing="CubicEaseInOut"/>
                </Transitions>
            </Setter>
            <Style.Animations>
                <Animation Duration="0:0:3" IterationCount="Infinite">
                    <KeyFrame Cue="0%">
                        <Setter Property="RotateTransform.Angle" Value="0" />
                    </KeyFrame>
                    <KeyFrame Cue="100%">
                        <Setter Property="RotateTransform.Angle" Value="360" />
                    </KeyFrame>
                </Animation>
            </Style.Animations>
        </Style>
        <Style Selector="Button:pointerover Rectangle.rectGradient">
            <Setter Property="Opacity" Value="1"/>
        </Style>
        <Style Selector="ComboBox /template/ Popup > Border">
            <Style.Animations>
                <Animation Duration="0:0:0.2" Easing="CubicEaseOut">
                    <KeyFrame Cue="0%">
                        <Setter Property="Opacity" Value="0"/>
                        <Setter Property="TranslateTransform.Y" Value="-10"/>
                    </KeyFrame>
                    <KeyFrame Cue="100%">
                        <Setter Property="Opacity" Value="1"/>
                        <Setter Property="TranslateTransform.Y" Value="0"/>
                    </KeyFrame>
                </Animation>
            </Style.Animations>
        </Style>
        <Style Selector="Button.windowControl">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#718096"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="46"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="CornerRadius" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style Selector="Button.windowControl:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="#33FFFFFF"/>
            <Setter Property="Foreground" Value="#E2E8F0"/>
        </Style>
        <Style Selector="Button.closeControl:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="#E81123"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
        <Style Selector="Button.countryControl:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="#2D3136"/>
        </Style>
        <Style Selector="Button.connectBtn:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="#1AFFFFFF"/>
        </Style>
        <Style Selector="Button.modeBtn:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="#1AFFFFFF"/>
        </Style>
        <Style Selector="TextBlock.modeText">
            <Setter Property="Foreground" Value="#8B949E"/>
        </Style>
        <Style Selector="Button.activeMode TextBlock.modeText">
            <Setter Property="Foreground" Value="White"/>
        </Style>
        <Style Selector="Button.modeBtn:pointerover TextBlock.modeText">
            <Setter Property="Foreground" Value="#E2E8F0"/>
        </Style>
        <Style Selector="Button.sidebarControl">
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#8B949E"/>
            <Setter Property="Padding" Value="0,12,0,12"/>
            <Setter Property="Margin" Value="6,0,6,0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="Button.sidebarControl:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="#2D3136"/>
            <Setter Property="Foreground" Value="#E2E8F0"/>
        </Style>

        <Style Selector="Border.sidebar">
            <Setter Property="Width" Value="64"/>
            <Setter Property="Transitions">
                <Transitions>
                    <DoubleTransition Property="Width" Duration="0:0:0.25" Easing="CubicEaseOut"/>
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Border.sidebar:pointerover">
            <Setter Property="Width" Value="175"/>
        </Style>
        
        <Style Selector="Border.sidebar TextBlock.sidebarText">
            <Setter Property="Opacity" Value="0"/>
            <Setter Property="Transitions">
                <Transitions>
                    <DoubleTransition Property="Opacity" Duration="0:0:0.25" Easing="CubicEaseOut"/>
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Border.sidebar:pointerover TextBlock.sidebarText">
            <Setter Property="Opacity" Value="1"/>
        </Style>



        <Style Selector="TextBlock.settingTitle">
            <Setter Property="Foreground" Value="#8B949E"/>
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="Foreground" Duration="0:0:0.2" Easing="CubicEaseOut"/>
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="TextBlock.settingTitle:pointerover">
            <Setter Property="Foreground" Value="#E2E8F0"/>
        </Style>

        <Style Selector="Border.popupContent">
            <Setter Property="Opacity" Value="0"/>
            <Setter Property="RenderTransform" Value="translateY(-10px)"/>
            <Setter Property="Transitions">
                <Transitions>
                    <DoubleTransition Property="Opacity" Duration="0:0:0.2" Easing="CubicEaseOut"/>
                    <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.2" Easing="CubicEaseOut"/>
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Border.popupContent.popupOpen">
            <Setter Property="Opacity" Value="1"/>
            <Setter Property="RenderTransform" Value="none"/>
        </Style>

        <Style Selector="Button.optBtn">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="#8B949E"/>
            <Setter Property="Padding" Value="8,4,8,4"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="CornerRadius" Value="6"/>
        </Style>
        <Style Selector="Button.optBtn:pointerover">
            <Setter Property="Foreground" Value="#E2E8F0"/>
            <Setter Property="Background" Value="#33FFFFFF"/>
        </Style>
        <Style Selector="Button.optBtn.activeOpt">
            <Setter Property="Foreground" Value="#E2E8F0"/>
            <Setter Property="Background" Value="#1AFFFFFF"/>
        </Style>

        <Style Selector="TextBlock.portHoverText">
            <Setter Property="Foreground" Value="#8B949E"/>
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="Foreground" Duration="0:0:0.2"/>
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="TextBlock.portHoverText:pointerover">
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style Selector="Button.graphHover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="Background" Duration="0:0:0.2"/>
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Button.graphHover:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="#1AFFFFFF"/>
        </Style>
    </Window.Styles>

    <Border CornerRadius="8" ClipToBounds="True" Background="#0A0C0F" BorderBrush="#2D3748" BorderThickness="1">
        <Grid>
            <Canvas Height="0" IsHitTestVisible="False">
                <Ellipse Width="1400" Height="1400" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="-150,-350,0,0" IsHitTestVisible="False" Opacity="0.7">
                    <Ellipse.Fill>
                        <SolidColorBrush Color="{DynamicResource ThemeGlow}">
                            <SolidColorBrush.Transitions>
                                <Transitions>
                                    <ColorTransition Property="Color" Duration="0:0:0.8" Easing="CubicEaseOut"/>
                                </Transitions>
                            </SolidColorBrush.Transitions>
                        </SolidColorBrush>
                    </Ellipse.Fill>
                    <Ellipse.OpacityMask>
                        <RadialGradientBrush GradientOrigin="50%,50%" Center="50%,50%" RadiusX="50%" RadiusY="50%">
                            <GradientStop Color="#FFFFFFFF" Offset="0"/>
                            <GradientStop Color="#00FFFFFF" Offset="1"/>
                        </RadialGradientBrush>
                    </Ellipse.OpacityMask>
                    <Ellipse.Styles>
                        <Style Selector="Ellipse">
                            <Style.Animations>
                                <Animation Duration="0:0:45" IterationCount="Infinite" PlaybackDirection="Alternate">
                                    <KeyFrame Cue="0%">
                                        <Setter Property="TranslateTransform.X" Value="0"/>
                                        <Setter Property="TranslateTransform.Y" Value="100"/>
                                    </KeyFrame>
                                    <KeyFrame Cue="25%">
                                        <Setter Property="TranslateTransform.X" Value="350"/>
                                        <Setter Property="TranslateTransform.Y" Value="150"/>
                                    </KeyFrame>
                                    <KeyFrame Cue="50%">
                                        <Setter Property="TranslateTransform.X" Value="100"/>
                                        <Setter Property="TranslateTransform.Y" Value="250"/>
                                    </KeyFrame>
                                    <KeyFrame Cue="75%">
                                        <Setter Property="TranslateTransform.X" Value="-300"/>
                                        <Setter Property="TranslateTransform.Y" Value="150"/>
                                    </KeyFrame>
                                    <KeyFrame Cue="100%">
                                        <Setter Property="TranslateTransform.X" Value="-150"/>
                                        <Setter Property="TranslateTransform.Y" Value="180"/>
                                    </KeyFrame>
                                </Animation>
                            </Style.Animations>
                        </Style>
                    </Ellipse.Styles>
                    <Ellipse.RenderTransform>
                        <TranslateTransform X="0" Y="0" />
                    </Ellipse.RenderTransform>
                </Ellipse>
            </Canvas>

            <Grid RowDefinitions="45, *">
                
                  <Grid Grid.Row="0" Background="#110A0C0F" PointerPressed="TitleBar_PointerPressed">
                      
                      <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="15,0,0,0" IsHitTestVisible="False">
                          <Image Source="avares://CrimsonOnion/Assets/icon.ico" Width="20" Height="20" RenderOptions.BitmapInterpolationMode="HighQuality"/>
                          <TextBlock Text="CrimsonOnion" VerticalAlignment="Center" Margin="10,0,0,0" FontSize="16" FontFamily="Segoe UI" FontWeight="SemiBold" Foreground="#E2E8F0"/>
                      </StackPanel>

                      <Button Name="btnTitleUpdate" Content="NEW UPDATE AVAILABLE" IsVisible="False"
                              HorizontalAlignment="Center" VerticalAlignment="Center"
                              Background="Transparent" Foreground="#68D391" FontWeight="Bold" FontSize="12"
                              Cursor="Hand" BorderThickness="0" Click="BtnTitleUpdate_Click"/>
  
                      <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top">
                        <Button Classes="windowControl" Content="&#x2013;" FontSize="14" Click="Minimize_Click"/>
                        <Button Classes="windowControl closeControl" Content="&#x2715;" FontSize="12" Click="Close_Click"/>
                    </StackPanel>
                </Grid>

                <Grid Grid.Row="1" ColumnDefinitions="Auto, *">
                    
                    <Border x:Name="SidebarBorder" Grid.Column="0" Classes="sidebar" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="15,10,15,15" CornerRadius="12" Background="#99141414" BorderBrush="#2D3748" BorderThickness="1" ClipToBounds="True" PointerEntered="SidebarBorder_PointerEntered" PointerExited="SidebarBorder_PointerExited" ZIndex="500">
                        <StackPanel VerticalAlignment="Top" Spacing="6" Margin="0,8,0,8">
                            <Button Classes="sidebarControl" Click="SidebarConnection_Click">
                                <Grid ColumnDefinitions="50, *">
                                    <PathIcon Grid.Column="0" Data="M3.9 12c0-1.71 1.39-3.1 3.1-3.1h4V7H7c-2.76 0-5 2.24-5 5s2.24 5 5 5h4v-1.9H7c-1.71 0-3.1-1.39-3.1-3.1zM8 13h8v-2H8v2zm9-6h-4v1.9h4c1.71 0 3.1 1.39 3.1 3.1s-1.39 3.1-3.1 3.1h-4V17h4c2.76 0 5-2.24 5-5s-2.24-5-5-5z" Width="22" Height="22" HorizontalAlignment="Center"/>
                                    <TextBlock x:Name="lblSidebarConnection" Grid.Column="1" Classes="sidebarText" Text="CONNECTION" VerticalAlignment="Center" FontSize="11" FontWeight="SemiBold" LetterSpacing="1" Margin="5,0,3,0"/>
                                </Grid>
                            </Button>
                            
                            <Button x:Name="btnCountries" Classes="sidebarControl" Click="SidebarCountries_Click" >
                                <Grid ColumnDefinitions="50, *">
                                    <PathIcon Grid.Column="0" Data="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 17.93c-3.95-.49-7-3.85-7-7.93 0-.62.08-1.21.21-1.79L9 15v1c0 1.1.9 2 2 2v1.93zm6.9-2.54c-.26-.81-1-1.39-1.9-1.39h-1v-3c0-.55-.45-1-1-1H8v-2h2c.55 0 1-.45 1-1V7h2c1.1 0 2-.9 2-2v-.41c2.93 1.19 5 4.06 5 7.41 0 2.08-.8 3.97-2.1 5.39z" Width="22" Height="22" HorizontalAlignment="Center"/>
                                    <TextBlock x:Name="lblSidebarCountries" Grid.Column="1" Classes="sidebarText" Text="COUNTRIES" VerticalAlignment="Center" FontSize="11" FontWeight="SemiBold" LetterSpacing="1" Margin="5,0,3,0"/>
                                </Grid>
                            </Button>

                            <Button x:Name="btnSplitTunnel" Classes="sidebarControl" Click="btnSplitTunnel_Click" >
                                <Grid ColumnDefinitions="50, *">
                                    <PathIcon Grid.Column="0" Data="M15 3l2.3 2.3-2.89 2.87 1.42 1.42L18.7 6.7 21 9V3zM3 9l2.3-2.3 2.87 2.89 1.42-1.42L6.7 5.3 9 3H3zm6 12l-2.3-2.3 2.89-2.87-1.42-1.42L5.3 17.3 3 15v6zm12-6l-2.3 2.3-2.87-2.89-1.42 1.42 2.89 2.87L15 21h6z" Width="20" Height="20" HorizontalAlignment="Center"/>
                                    <TextBlock x:Name="lblSidebarSplitTunnel" Grid.Column="1" Classes="sidebarText" Text="SPLIT TUNNEL" VerticalAlignment="Center" FontSize="11" FontWeight="SemiBold" LetterSpacing="1" Margin="5,0,3,0"/>
                                </Grid>
                            </Button>

                            <Button x:Name="btnSettings" Classes="sidebarControl" Click="btnSettings_Click">
                                <Grid ColumnDefinitions="50, *">
                                    <PathIcon Grid.Column="0" Data="M19.43 12.98c.04-.32.07-.64.07-.98 0-.34-.03-.66-.07-.98l2.11-1.65c.19-.15.24-.42.12-.64l-2-3.46c-.12-.22-.39-.3-.61-.22l-2.49 1c-.52-.4-1.08-.73-1.69-.98l-.38-2.65A.488.488 0 0 0 14 2h-4c-.25 0-.46.18-.5.42l-.38 2.65c-.61.25-1.17.59-1.69.98l-2.49-1c-.23-.09-.49 0-.61.22l-2 3.46c-.13.22-.07.49.12.64l2.11 1.65c-.04.32-.07.65-.07.98s.03.66.07.98l-2.11 1.65c-.19.15-.24.42-.12.64l2 3.46c.12.22.39.3.61.22l2.49-1c.52.4 1.08.73 1.69.98l.38 2.65c.03.24.24.42.5.42h4c.25 0 .46-.18.5-.42l.38-2.65c.61-.25 1.17-.59 1.69-.98l2.49 1c.23.09.49 0 .61-.22l2-3.46c.12-.22.07-.49-.12-.64l-2.11-1.65zM12 15.5c-1.93 0-3.5-1.57-3.5-3.5s1.57-3.5 3.5-3.5 3.5 1.57 3.5 3.5-1.57 3.5-3.5 3.5z" Width="22" Height="22" HorizontalAlignment="Center"/>
                                    <TextBlock x:Name="lblSidebarSettings" Grid.Column="1" Classes="sidebarText" Text="SETTINGS" VerticalAlignment="Center" FontSize="11" FontWeight="SemiBold" LetterSpacing="1" Margin="5,0,3,0"/>
                                </Grid>
                            </Button>

                            <Button Classes="sidebarControl" Click="SidebarAbout_Click">
                                <Grid ColumnDefinitions="50, *">
                                    <PathIcon Grid.Column="0" Data="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-6h2v6zm0-8h-2V7h2v2z" Width="22" Height="22" HorizontalAlignment="Center"/>
                                    <TextBlock x:Name="lblSidebarAbout" Grid.Column="1" Classes="sidebarText" Text="ABOUT" VerticalAlignment="Center" FontSize="11" FontWeight="SemiBold" LetterSpacing="1" Margin="5,0,3,0"/>
                                </Grid>
                            </Button>
                            <Button x:Name="btnThemes" Classes="sidebarControl" Click="SidebarThemes_Click" Height="40" Padding="0">
                                <Button.Styles>
                                    <Style Selector="Button:pointerover /template/ ContentPresenter#PART_ContentPresenter">
                                        <Setter Property="Background" Value="Transparent"/>
                                    </Style>
                                </Button.Styles>
                                <Panel>
                                    <Border x:Name="rectAllThemes" Opacity="0" CornerRadius="12" ClipToBounds="True">
                                        <Border.Transitions>
                                            <Transitions>
                                                <DoubleTransition Property="Opacity" Duration="0:0:0.3"/>
                                            </Transitions>
                                        </Border.Transitions>
                                        <Panel Classes="animatedGradient" Background="Transparent" ClipToBounds="True">
                                            <Rectangle Fill="{DynamicResource ThemeAllBrush}" RadiusX="12" RadiusY="12"/>
                                            <Rectangle Classes="rectGradient" Width="500" Height="500" HorizontalAlignment="Center" VerticalAlignment="Center" Fill="{DynamicResource ThemeAllBrush}">
                                                <Rectangle.RenderTransform><RotateTransform Angle="0"/></Rectangle.RenderTransform>
                                            </Rectangle>
                                        </Panel>
                                    </Border>
                                    <Grid ColumnDefinitions="50, *" Margin="0,0,0,0">
                                        <Border x:Name="borderCurrentThemeIcon" Grid.Column="0" Grid.ColumnSpan="2" Height="40" CornerRadius="12" HorizontalAlignment="Stretch" Margin="5,0,5,0" ClipToBounds="True">
                                            <Panel x:Name="panCurrentThemeIcon" Classes="animatedGradient" Background="Transparent" ClipToBounds="True">
                                                <Panel.Transitions>
                                                    <Transitions>
                                                        <DoubleTransition Property="Opacity" Duration="0:0:0.3"/>
                                                    </Transitions>
                                                </Panel.Transitions>
<Rectangle Fill="{DynamicResource ThemeCurrentBrush}" RadiusX="12" RadiusY="12"/>
<Rectangle Classes="rectGradient" Width="500" Height="500" HorizontalAlignment="Center" VerticalAlignment="Center" Fill="{DynamicResource ThemeCurrentBrush}">
    <Rectangle.RenderTransform><RotateTransform Angle="0"/></Rectangle.RenderTransform>
</Rectangle>
                                            </Panel>
                                        </Border>
                                    </Grid>
                                </Panel>
                            </Button>
                            <Border x:Name="panThemeSelector" IsVisible="True" Opacity="0" MaxHeight="0" ClipToBounds="True">
                                <Border.Transitions>
                                    <Transitions>
                                        <DoubleTransition Property="Opacity" Duration="0:0:0.3"/>
                                        <DoubleTransition Property="MaxHeight" Duration="0:0:0.3" Easing="CubicEaseOut"/>
                                    </Transitions>
                                </Border.Transitions>
                                <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto" Margin="6,5,6,5">
                                    <!-- Crimson -->
                                    <Button Classes="ThemeColorButton" Grid.Row="0" Grid.Column="0" Cursor="Hand" Click="ThemeSelect_Click" CommandParameter="Crimson" Margin="0,0,2.5,5" Background="Transparent" Padding="0" BorderThickness="0" HorizontalAlignment="Stretch">
                                        <Border Height="40" HorizontalAlignment="Stretch" CornerRadius="12" ClipToBounds="True">
                                            <Panel Classes="animatedGradient" Background="Transparent">
<Rectangle Fill="{DynamicResource ThemeCrimsonBrush}" RadiusX="12" RadiusY="12"/>
<Rectangle Classes="rectGradient" Width="200" Height="200" HorizontalAlignment="Center" VerticalAlignment="Center" Fill="{DynamicResource ThemeCrimsonBrush}">
    <Rectangle.RenderTransform><RotateTransform Angle="0"/></Rectangle.RenderTransform>
</Rectangle>
                                            </Panel>
                                        </Border>
                                    </Button>
                                    <!-- Blue -->
                                    <Button Classes="ThemeColorButton" Grid.Row="0" Grid.Column="1" Cursor="Hand" Click="ThemeSelect_Click" CommandParameter="Blue" Margin="2.5,0,0,5" Background="Transparent" Padding="0" BorderThickness="0" HorizontalAlignment="Stretch">
                                        <Border Height="40" HorizontalAlignment="Stretch" CornerRadius="12" ClipToBounds="True">
                                            <Panel Classes="animatedGradient" Background="Transparent">
<Rectangle Fill="{DynamicResource ThemeBlueBrush}" RadiusX="12" RadiusY="12"/>
<Rectangle Classes="rectGradient" Width="200" Height="200" HorizontalAlignment="Center" VerticalAlignment="Center" Fill="{DynamicResource ThemeBlueBrush}">
    <Rectangle.RenderTransform><RotateTransform Angle="0"/></Rectangle.RenderTransform>
</Rectangle>
                                            </Panel>
                                        </Border>
                                    </Button>
                                    <!-- Purple -->
                                    <Button Classes="ThemeColorButton" Grid.Row="1" Grid.Column="0" Cursor="Hand" Click="ThemeSelect_Click" CommandParameter="Purple" Margin="0,0,2.5,5" Background="Transparent" Padding="0" BorderThickness="0" HorizontalAlignment="Stretch">
                                        <Border Height="40" HorizontalAlignment="Stretch" CornerRadius="12" ClipToBounds="True">
                                            <Panel Classes="animatedGradient" Background="Transparent">
<Rectangle Fill="{DynamicResource ThemePurpleBrush}" RadiusX="12" RadiusY="12"/>
<Rectangle Classes="rectGradient" Width="200" Height="200" HorizontalAlignment="Center" VerticalAlignment="Center" Fill="{DynamicResource ThemePurpleBrush}">
    <Rectangle.RenderTransform><RotateTransform Angle="0"/></Rectangle.RenderTransform>
</Rectangle>
                                            </Panel>
                                        </Border>
                                    </Button>
                                    <!-- Green -->
                                    <Button Classes="ThemeColorButton" Grid.Row="1" Grid.Column="1" Cursor="Hand" Click="ThemeSelect_Click" CommandParameter="Green" Margin="2.5,0,0,5" Background="Transparent" Padding="0" BorderThickness="0" HorizontalAlignment="Stretch">
                                        <Border Height="40" HorizontalAlignment="Stretch" CornerRadius="12" ClipToBounds="True">
                                            <Panel Classes="animatedGradient" Background="Transparent">
<Rectangle Fill="{DynamicResource ThemeGreenBrush}" RadiusX="12" RadiusY="12"/>
<Rectangle Classes="rectGradient" Width="200" Height="200" HorizontalAlignment="Center" VerticalAlignment="Center" Fill="{DynamicResource ThemeGreenBrush}">
    <Rectangle.RenderTransform><RotateTransform Angle="0"/></Rectangle.RenderTransform>
</Rectangle>
                                            </Panel>
                                        </Border>
                                    </Button>
                                    <!-- Pink -->
                                    <Button Classes="ThemeColorButton" Grid.Row="2" Grid.Column="0" Cursor="Hand" Click="ThemeSelect_Click" CommandParameter="Pink" Margin="0,0,2.5,0" Background="Transparent" Padding="0" BorderThickness="0" HorizontalAlignment="Stretch">
                                        <Border Height="40" HorizontalAlignment="Stretch" CornerRadius="12" ClipToBounds="True">
                                            <Panel Classes="animatedGradient" Background="Transparent">
<Rectangle Fill="{DynamicResource ThemePinkBrush}" RadiusX="12" RadiusY="12"/>
<Rectangle Classes="rectGradient" Width="200" Height="200" HorizontalAlignment="Center" VerticalAlignment="Center" Fill="{DynamicResource ThemePinkBrush}">
    <Rectangle.RenderTransform><RotateTransform Angle="0"/></Rectangle.RenderTransform>
</Rectangle>
                                            </Panel>
                                        </Border>
                                    </Button>
                                    <!-- Yellow -->
                                    <Button Classes="ThemeColorButton" Grid.Row="2" Grid.Column="1" Cursor="Hand" Click="ThemeSelect_Click" CommandParameter="Yellow" Margin="2.5,0,0,0" Background="Transparent" Padding="0" BorderThickness="0" HorizontalAlignment="Stretch">
                                        <Border Height="40" HorizontalAlignment="Stretch" CornerRadius="12" ClipToBounds="True">
                                            <Panel Classes="animatedGradient" Background="Transparent">
<Rectangle Fill="{DynamicResource ThemeYellowBrush}" RadiusX="12" RadiusY="12"/>
<Rectangle Classes="rectGradient" Width="200" Height="200" HorizontalAlignment="Center" VerticalAlignment="Center" Fill="{DynamicResource ThemeYellowBrush}">
    <Rectangle.RenderTransform><RotateTransform Angle="0"/></Rectangle.RenderTransform>
</Rectangle>
                                            </Panel>
                                        </Border>
                                    </Button>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Border>
                    
                    <Grid x:Name="panMainInteraction" Grid.Column="1" HorizontalAlignment="Stretch" VerticalAlignment="Top" Margin="0,20,0,0">
                        <Grid RowDefinitions="Auto, Auto, Auto">
                            
                            <Button x:Name="btnCurrentCountry" Grid.Row="0" Background="Transparent" BorderThickness="0" CornerRadius="6" HorizontalAlignment="Center" Margin="0,0,0,10" Padding="15,8,15,8" Cursor="Hand" Click="MainCountries_Click">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <PathIcon x:Name="iconCurrentRouting" Data="M7 2v11h3v9l7-12h-4l4-8z" Width="14" Height="14" Foreground="#E2E8F0" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="txtCurrentRouting" Text="OPTIMIZED" FontSize="14" FontWeight="SemiBold" Foreground="#E2E8F0" VerticalAlignment="Center"/>
                                    <PathIcon Data="M7 10l5 5 5-5z" Width="10" Height="10" Foreground="#8B949E" VerticalAlignment="Center" Margin="2,2,0,0"/>
                                </StackPanel>
                            </Button>

                              <Panel Grid.Row="1" HorizontalAlignment="Center">
                                  <Border x:Name="panConnectGlow" CornerRadius="13" ClipToBounds="True" Opacity="0" Margin="-2">
                                      <Border.Transitions>
                                          <Transitions>
                                              <DoubleTransition Property="Opacity" Duration="0:0:0.4" Easing="CubicEaseInOut"/>
                                          </Transitions>
                                      </Border.Transitions>
                                      <Panel>
                                          <Panel HorizontalAlignment="Center" VerticalAlignment="Center">
                                              <Rectangle Width="800" Height="800" Margin="-400">
                                                  <Rectangle.RenderTransform><RotateTransform Angle="0"/></Rectangle.RenderTransform>
                                                  <Rectangle.Fill>
                                                      <ConicGradientBrush Center="50%,50%" Angle="0">
                                                          <GradientStop Color="#00000000" Offset="0"/>
                                                          <GradientStop Color="{DynamicResource ThemeGlow}" Offset="0.1"/>
                                                          <GradientStop Color="#00000000" Offset="0.15"/>
                                                          <GradientStop Color="#00000000" Offset="0.5"/>
                                                          <GradientStop Color="{DynamicResource ThemeGlow}" Offset="0.6"/>
                                                          <GradientStop Color="#00000000" Offset="0.65"/>
                                                      </ConicGradientBrush>
                                                  </Rectangle.Fill>
                                                  <Rectangle.Styles>
                                                      <Style Selector="Rectangle">
                                                          <Style.Animations>
                                                              <Animation Duration="0:0:3" IterationCount="INFINITE">
                                                                  <KeyFrame Cue="0%">
                                                                      <Setter Property="RotateTransform.Angle" Value="0"/>
                                                                  </KeyFrame>
                                                                  <KeyFrame Cue="100%">
                                                                      <Setter Property="RotateTransform.Angle" Value="360"/>
                                                                  </KeyFrame>
                                                              </Animation>
                                                          </Style.Animations>
                                                      </Style>
                                                  </Rectangle.Styles>
                                              </Rectangle>
                                          </Panel>
                                          
                                          <Border Margin="2" CornerRadius="12" Background="#0A0C0F" />
                                      </Panel>
                                  </Border>

                                  <Border Background="#99141414" BorderBrush="#2D3748" BorderThickness="1" CornerRadius="12" Padding="3">
                                      <Grid RowDefinitions="Auto, Auto">
                                          
                                          <Button x:Name="btnConnect" Grid.Row="0" Classes="connectBtn" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Background="Transparent" BorderThickness="0" CornerRadius="8" Padding="0,8,0,8" Cursor="Hand" Margin="2,2,2,2" Click="btnConnect_Click">
                                              <TextBlock x:Name="txtConnectBtn" Text="CONNECT" FontSize="19" FontWeight="Bold" LetterSpacing="2" Foreground="#E2E8F0" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                          </Button>

                                          <Grid Grid.Row="1" ColumnDefinitions="Auto, Auto, Auto, Auto, Auto" Margin="0">
                                              <Button x:Name="btnProxyMode" Grid.Column="0" Classes="modeBtn activeMode" Background="Transparent" BorderThickness="0" CornerRadius="6" Padding="14,8,14,8" Margin="2,2,2,2" Cursor="Hand" Click="Mode_Click" >
                                                  <TextBlock x:Name="lblProxyMode" Classes="modeText" Text="PROXY MODE" FontSize="11" FontWeight="SemiBold"/>
                                              </Button>
                                              
                                              <Border Grid.Column="1" Width="1" Background="#2D3748" Margin="0,6,0,6"/>
                                              
                                              <Panel x:Name="panVpnMode" Grid.Column="2" Background="Transparent" Margin="2,2,2,2">
                                                  <Button x:Name="btnVpnMode" Classes="modeBtn" Background="Transparent" BorderThickness="0" CornerRadius="6" Padding="14,8,14,8" Cursor="Hand" Click="Mode_Click" >
                                                      <TextBlock x:Name="lblVpnMode" Classes="modeText" Text="VPN MODE" FontSize="11" FontWeight="SemiBold"/>
                                                  </Button>
                                              </Panel>
                                              
                                              <Border Grid.Column="3" Width="1" Background="#2D3748" Margin="0,6,0,6"/>
                                              
                                              <Button x:Name="btnClearProxy" Grid.Column="4" Classes="modeBtn" Background="Transparent" BorderThickness="0" CornerRadius="6" Padding="14,8,14,8" Margin="2,2,2,2" Cursor="Hand" Click="Mode_Click" >
                                                  <TextBlock x:Name="lblClearProxy" Classes="modeText" Text="CLEAR PROXY" FontSize="11" FontWeight="SemiBold"/>
                                              </Button>
                                          </Grid>
                                      </Grid>
                                  </Border>
                              </Panel>

                            <Border x:Name="panMainConfig" Grid.Row="2" Background="#99141414" BorderBrush="#2D3748" BorderThickness="1" CornerRadius="12" Padding="6" Margin="10,50,25,15" HorizontalAlignment="Stretch">
                                <StackPanel Spacing="6">
                                    
                                    <Border Background="#400A0C0F" BorderBrush="#2D3748" BorderThickness="1" CornerRadius="8" Padding="12,8">
                                        <StackPanel>
                                            <Grid ColumnDefinitions="Auto, *, Auto" MinHeight="36">
                                                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                                                    <PathIcon Data="M21 16v-2l-8-5V3.5c0-.83-.67-1.5-1.5-1.5S10 2.67 10 3.5V9l-8 5v2l8-2.5V19l-2 1.5V22l3.5-1 3.5 1v-1.5L13 19v-5.5l8 2.5z" Width="14" Height="14" Foreground="#8B949E"/>
                                                    <TextBlock x:Name="lblBridgeType" Text="BRIDGE TYPE" FontSize="11" FontWeight="SemiBold" Foreground="#8B949E" LetterSpacing="1" VerticalAlignment="Center"/>
                                                </StackPanel>

                                                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center" Margin="15,0,0,0">
                                                    <Button x:Name="btnBridgeDirect" Classes="optBtn activeOpt" Click="Bridge_Click"><TextBlock Text="DIRECT" FontSize="11" FontWeight="SemiBold"/></Button>
                                                    <Button x:Name="btnBridgeObfs4" Classes="optBtn" Click="Bridge_Click"><TextBlock Text="OBFS4" FontSize="11" FontWeight="SemiBold"/></Button>
                                                    <Button x:Name="btnBridgeSnowflake" Classes="optBtn" Click="Bridge_Click"><TextBlock Text="SNOWFLAKE" FontSize="11" FontWeight="SemiBold"/></Button>
                                                    <Button x:Name="btnBridgeMeek" Classes="optBtn" Click="Bridge_Click"><TextBlock Text="MEEK" FontSize="11" FontWeight="SemiBold"/></Button>
                                                    <Button x:Name="btnBridgeCustom" Classes="optBtn" Click="Bridge_Click"><TextBlock Text="CUSTOM" FontSize="11" FontWeight="SemiBold"/></Button>
                                                </StackPanel>
                                            </Grid>

                                            <Border x:Name="panCustomBridge" Background="Transparent" BorderThickness="0" ClipToBounds="True" MaxHeight="0" Opacity="0">
                                                <Border.Transitions>
                                                    <Transitions>
                                                        <DoubleTransition Property="MaxHeight" Duration="0:0:0.3" Easing="CubicEaseOut"/>
                                                        <DoubleTransition Property="Opacity" Duration="0:0:0.3" Easing="CubicEaseOut"/>
                                                    </Transitions>
                                                </Border.Transitions>
                                                <StackPanel Spacing="6" Margin="0,8,0,0">
                                            <Grid ColumnDefinitions="*, Auto, 140" Height="110" Margin="0,0,0,6">
                                                <TextBox x:Name="txtCustomBridge" Grid.Column="0" AcceptsReturn="True" TextWrapping="Wrap" Background="#1A1C20" Foreground="#68D391" BorderBrush="#2D3748" BorderThickness="1" FontFamily="Consolas" FontSize="11" CornerRadius="4" Margin="0,0,10,0" VerticalAlignment="Stretch"/>

                                                <Border x:Name="panCaptcha" Grid.Column="1" Background="#1A1C20" BorderBrush="#2D3748" BorderThickness="1" CornerRadius="4" Padding="2" MaxHeight="0" MaxWidth="0" Opacity="0" ClipToBounds="True" Margin="0,0,0,0" VerticalAlignment="Stretch">
                                                    <Border.Transitions>
                                                        <Transitions>
                                                            <DoubleTransition Property="MaxHeight" Duration="0:0:0.3" Easing="CubicEaseOut"/>
                                                            <DoubleTransition Property="MaxWidth" Duration="0:0:0.3" Easing="CubicEaseOut"/>
                                                            <DoubleTransition Property="Opacity" Duration="0:0:0.3" Easing="CubicEaseOut"/>
                                                            <ThicknessTransition Property="Margin" Duration="0:0:0.3" Easing="CubicEaseOut"/>
                                                        </Transitions>
                                                    </Border.Transitions>
                                                    <Grid Width="140">
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="Auto"/>
                                                            <RowDefinition Height="*"/>
                                                            <RowDefinition Height="26"/>
                                                        </Grid.RowDefinitions>
                                                        <Image x:Name="imgCaptcha" Grid.Row="0" Height="40" Stretch="Uniform" Margin="0,0,0,6"/>
                                                        <TextBox x:Name="txtCaptchaSol" KeyDown="txtCaptchaSol_KeyDown" Grid.Row="1" MinHeight="20" PlaceholderText="ENTER CAPTCHA" Background="#0A0C0F" Foreground="#E2E8F0" BorderBrush="#3A3F44" BorderThickness="1" Padding="0" FontFamily="Consolas" FontSize="10" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Margin="1.5,0,1.5,6" VerticalAlignment="Stretch"/>
                                                        <Grid Grid.Row="2" ColumnDefinitions="*,1,*">
                                                            <Button x:Name="btnCaptchaSubmit" Click="btnCaptchaSubmit_Click" Grid.Column="0" Content="SUBMIT" FontSize="9" FontWeight="Bold" Background="#4E7A5E" Foreground="#FFF" CornerRadius="3" Margin="1.5" Padding="0" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" VerticalAlignment="Stretch" VerticalContentAlignment="Center"/>
                                                            <Button x:Name="btnCaptchaCancel" Click="btnCaptchaCancel_Click" Grid.Column="2" Content="CANCEL" FontSize="9" FontWeight="Bold" Background="#8B4A4A" Foreground="#FFF" CornerRadius="3" Margin="1.5" Padding="0" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" VerticalAlignment="Stretch" VerticalContentAlignment="Center"/>
                                                        </Grid>
                                                    </Grid>
                                                </Border>

                                                <Grid Grid.Column="2" Margin="0,0,0,0">
                                                    <Border VerticalAlignment="Top" HorizontalAlignment="Right" Width="140" Background="#1A1C20" BorderBrush="#2D3748" BorderThickness="1" CornerRadius="4">
                                                        <Grid>
                                                            <Grid.RowDefinitions>
                                                                <RowDefinition Height="26"/>
                                                                <RowDefinition Height="1"/>
                                                                <RowDefinition Height="26"/>
                                                                <RowDefinition Height="1"/>
                                                                <RowDefinition Height="26"/>
                                                                <RowDefinition Height="1"/>
                                                                <RowDefinition Height="26"/>
                                                            </Grid.RowDefinitions>
                                                            
                                                            <TextBlock x:Name="lblGetBridges" Grid.Row="0" Text="GET BRIDGES" FontSize="10" FontWeight="Bold" Foreground="#A0AEC0" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,-1,0,0"/>
                                                            <Border Grid.Row="1" Background="#2D3748"/>
                                                            
                                                            <Button x:Name="btnGetWebTunnel" Click="btnGetWebTunnel_Click" Grid.Row="2" Content="WEBTUNNEL" FontSize="10" FontWeight="Bold" Foreground="#E2E8F0" Background="Transparent" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" VerticalAlignment="Stretch" Cursor="Hand" BorderThickness="0" CornerRadius="0">
                                                                <Button.Styles>
                                                                    <Style Selector="Button:pointerover /template/ ContentPresenter">
                                                                        <Setter Property="Background" Value="#25FFFFFF"/>
                                                                    </Style>
                                                                </Button.Styles>
                                                            </Button>
                                                            <Border Grid.Row="3" Background="#2D3748"/>
                                                            
                                                            <Button x:Name="btnGetObfs4" Click="btnGetObfs4_Click" Grid.Row="4" Content="OBFS4" FontSize="10" FontWeight="Bold" Foreground="#E2E8F0" Background="Transparent" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" VerticalAlignment="Stretch" Cursor="Hand" BorderThickness="0" CornerRadius="0">
                                                                <Button.Styles>
                                                                    <Style Selector="Button:pointerover /template/ ContentPresenter">
                                                                        <Setter Property="Background" Value="#25FFFFFF"/>
                                                                    </Style>
                                                                </Button.Styles>
                                                            </Button>
                                                            <Border Grid.Row="5" Background="#2D3748"/>
                                                            
                                                            <Border Grid.Row="6" Background="#0A0C0F" CornerRadius="0,0,3,3">
                                                                <Grid>
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="*"/>
                                                                        <ColumnDefinition Width="1"/>
                                                                        <ColumnDefinition Width="*"/>
                                                                    </Grid.ColumnDefinitions>
                                                                    <Button x:Name="btnCustomSave" Click="btnCustomSave_Click" Grid.Column="0" Content="SAVE" FontSize="10" FontWeight="Bold" Foreground="#A0AEC0" Background="Transparent" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" VerticalAlignment="Stretch" Cursor="Hand" BorderThickness="0" CornerRadius="0">
                                                                        <Button.Styles>
                                                                            <Style Selector="Button:pointerover /template/ ContentPresenter">
                                                                                <Setter Property="Background" Value="#2AFFFFFF"/>
                                                                            </Style>
                                                                        </Button.Styles>
                                                                    </Button>
                                                                    <Border Grid.Column="1" Background="#2D3748"/>
                                                                    <Button x:Name="btnCustomCancel" Click="btnCustomCancel_Click" Grid.Column="2" Content="CANCEL" FontSize="10" FontWeight="Bold" Foreground="#A0AEC0" Background="Transparent" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" VerticalAlignment="Stretch" Cursor="Hand" BorderThickness="0" CornerRadius="0">
                                                                        <Button.Styles>
                                                                            <Style Selector="Button:pointerover /template/ ContentPresenter">
                                                                                <Setter Property="Background" Value="#2AFFFFFF"/>
                                                                            </Style>
                                                                        </Button.Styles>
                                                                    </Button>
                                                                </Grid>
                                                            </Border>
                                                        </Grid>
                                                    </Border>
                                                </Grid>
                                            </Grid>
                                        </StackPanel>
                                    </Border>
                                        </StackPanel>
                                    </Border>

                                    <Border Background="#400A0C0F" BorderBrush="#2D3748" BorderThickness="1" CornerRadius="8" Padding="12,8">
                                        <Grid ColumnDefinitions="Auto, *, Auto" MinHeight="36">
                                            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                                                <PathIcon Data="M20 13H4c-.55 0-1 .45-1 1v6c0 .55.45 1 1 1h16c.55 0 1-.45 1-1v-6c0-.55-.45-1-1-1zm0-10H4c-.55 0-1 .45-1 1v6c0 .55.45 1 1 1h16c.55 0 1-.45 1-1V4c0-.55-.45-1-1-1zM7 19c-1.1 0-2-.9-2-2s.9-2 2-2 2 .9 2 2-.9 2-2 2zM7 9c-1.1 0-2-.9-2-2s.9-2 2-2 2 .9 2 2-.9 2-2 2z" Width="14" Height="14" Foreground="#8B949E"/>
                                                <TextBlock x:Name="lblTorEngines" Text="TOR ENGINES" FontSize="11" FontWeight="SemiBold" Foreground="#8B949E" LetterSpacing="1" VerticalAlignment="Center"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center" Margin="15,0,0,0">
                                                <Slider x:Name="sldEngines" Minimum="1" Maximum="8" Value="1" TickFrequency="1" IsSnapToTickEnabled="True" Width="220" Margin="0,-12,0,-12" VerticalAlignment="Center" ValueChanged="Engines_ValueChanged" Foreground="{DynamicResource ThemeAccent}">
                                                    <Slider.Styles>
                                                        <Style Selector="Slider /template/ Thumb">
                                                            <Setter Property="Template">
                                                                <ControlTemplate>
                                                                    <Border Background="{DynamicResource ThemeAccent}" Width="24" Height="10" CornerRadius="4" />
                                                                </ControlTemplate>
                                                            </Setter>
                                                        </Style>
                                                        <Style Selector="Slider:pointerover /template/ Thumb">
                                                            <Setter Property="Template">
                                                                <ControlTemplate>
                                                                    <Border Background="{DynamicResource ThemeAccentPointerOver}" Width="24" Height="10" CornerRadius="4" />
                                                                </ControlTemplate>
                                                            </Setter>
                                                        </Style>
                                                    </Slider.Styles>
                                                </Slider>
                                                <TextBlock x:Name="lblEngineCount" Text="1" FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>

                                      <Border Background="#400A0C0F" BorderBrush="#2D3748" BorderThickness="1" CornerRadius="8" Padding="12,8">
                                        <StackPanel>
                                            <Grid ColumnDefinitions="Auto, *, Auto" MinHeight="36">
                                                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                                                    <PathIcon Data="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm-5 14H7v-2h7v2zm3-4H7v-2h10v2zm0-4H7V7h10v2z" Width="14" Height="14" Foreground="#8B949E"/>
                                                    <TextBlock x:Name="lblLogsStatus" Text="LOGS &amp; STATUS" FontSize="11" FontWeight="SemiBold" Foreground="#8B949E" LetterSpacing="1" VerticalAlignment="Center"/>
                                                </StackPanel>
                                                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center" Margin="15,0,0,0">
                                                    <ToggleSwitch x:Name="chkLogs" IsCheckedChanged="chkLogs_CheckedChanged" OnContent="{x:Null}" OffContent="{x:Null}" FontSize="11" Foreground="#8B949E"/>
                                                </StackPanel>
                                            </Grid>

                                            <Border x:Name="panLogs" Background="Transparent" BorderThickness="0" ClipToBounds="True" MaxHeight="0" Opacity="0">
                                        <Border.Transitions>
                                            <Transitions>
                                                <DoubleTransition Property="MaxHeight" Duration="0:0:0.3" Easing="CubicEaseOut"/>
                                                <DoubleTransition Property="Opacity" Duration="0:0:0.3" Easing="CubicEaseOut"/>
                                            </Transitions>
                                        </Border.Transitions>
                                        <Grid ColumnDefinitions="Auto,*" Margin="0,5,0,0">
                                            <StackPanel Grid.Column="0">
                                                <TextBlock x:Name="lblTorBootstrap" Text="TOR BOOTSTRAP" FontSize="10" FontWeight="Bold" Foreground="#A0AEC0" Margin="0,0,0,5"/>
                                                <Grid RowDefinitions="*,*,*,*" ColumnDefinitions="95,95" Height="100">
                                                    <TextBlock x:Name="lblTor1" Grid.Row="0" Grid.Column="0" Text="TOR 01: DISABLED" FontSize="10" Foreground="#A0AEC0" Opacity="0.5" VerticalAlignment="Center"/>
                                                    <TextBlock x:Name="lblTor2" Grid.Row="1" Grid.Column="0" Text="TOR 02: DISABLED" FontSize="10" Foreground="#A0AEC0" Opacity="0.5" VerticalAlignment="Center"/>
                                                    <TextBlock x:Name="lblTor3" Grid.Row="2" Grid.Column="0" Text="TOR 03: DISABLED" FontSize="10" Foreground="#A0AEC0" Opacity="0.5" VerticalAlignment="Center"/>
                                                    <TextBlock x:Name="lblTor4" Grid.Row="3" Grid.Column="0" Text="TOR 04: DISABLED" FontSize="10" Foreground="#A0AEC0" Opacity="0.5" VerticalAlignment="Center"/>
                                                    <TextBlock x:Name="lblTor5" Grid.Row="0" Grid.Column="1" Text="TOR 05: DISABLED" FontSize="10" Foreground="#A0AEC0" Opacity="0.5" VerticalAlignment="Center"/>
                                                    <TextBlock x:Name="lblTor6" Grid.Row="1" Grid.Column="1" Text="TOR 06: DISABLED" FontSize="10" Foreground="#A0AEC0" Opacity="0.5" VerticalAlignment="Center"/>
                                                    <TextBlock x:Name="lblTor7" Grid.Row="2" Grid.Column="1" Text="TOR 07: DISABLED" FontSize="10" Foreground="#A0AEC0" Opacity="0.5" VerticalAlignment="Center"/>
                                                    <TextBlock x:Name="lblTor8" Grid.Row="3" Grid.Column="1" Text="TOR 08: DISABLED" FontSize="10" Foreground="#A0AEC0" Opacity="0.5" VerticalAlignment="Center"/>
                                                </Grid>
                                            </StackPanel>

                                            <StackPanel Grid.Column="1" Margin="25,0,0,0">
                                                <TextBlock x:Name="lblXrayLogHeader" Text="CONNECTIONS (XRAY LOG)" FontSize="10" FontWeight="Bold" Foreground="#A0AEC0" Margin="0,0,0,5"/>
                                                <TextBox x:Name="txtXrayLogs" Height="100" AcceptsReturn="True" TextWrapping="Wrap" Background="#1A1C20" Foreground="#68D391" BorderBrush="#2D3748" BorderThickness="1" FontFamily="Consolas" FontSize="10" CornerRadius="4" IsReadOnly="True" ScrollViewer.HorizontalScrollBarVisibility="Disabled" ScrollViewer.VerticalScrollBarVisibility="Auto"/>
                                            </StackPanel>
                                        </Grid>
                                            </Border>
                                          </StackPanel>
                                      </Border>

                                      <Border Background="#400A0C0F" BorderBrush="#2D3748" BorderThickness="1" CornerRadius="8" Padding="12,8">
                                          <StackPanel>
                                                <Border x:Name="panStats" Background="Transparent" BorderThickness="0">
                                                    <Grid ColumnDefinitions="*,Auto" Margin="0,5,0,0">
                                                        <Grid x:Name="panLeftStats" Grid.Column="0" RowDefinitions="Auto, *">
                                                            <Grid.Transitions>
                                                                <Transitions>
                                                                    <DoubleTransition Property="Opacity" Duration="0:0:0.3" Easing="CubicEaseOut"/>
                                                                </Transitions>
                                                            </Grid.Transitions>
                                                            
                                                            <Panel Grid.Row="0" MinHeight="36" Margin="5,-10,0,0">
                                                                <StackPanel x:Name="panTimerContent" HorizontalAlignment="Left" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center" IsVisible="False">
                                                                    <TextBlock x:Name="lblConnectedFor" Text="CONNECTED FOR" FontSize="11" FontWeight="SemiBold" Foreground="#A0AEC0" VerticalAlignment="Center"/>
                                                                    <TextBlock x:Name="lblTimer" Text="00:00:00" FontSize="11" FontWeight="SemiBold" Foreground="#68D391" LetterSpacing="1" VerticalAlignment="Center"/>
                                                                    <TextBlock x:Name="lblConnectedTo" Text="TO" FontSize="11" FontWeight="SemiBold" Foreground="#A0AEC0" VerticalAlignment="Center"/>
                                                                    <TextBlock x:Name="lblCountryName" Text="UNKNOWN" FontSize="11" FontWeight="Bold" Foreground="#A0AEC0" VerticalAlignment="Center"/>
                                                                </StackPanel>
                                                                <TextBlock x:Name="lblDisconnected" HorizontalAlignment="Left" Text="DISCONNECTED" FontSize="11" FontWeight="SemiBold" Foreground="#A0AEC0" VerticalAlignment="Center"/>
                                                            </Panel>

                                                            <Button Grid.Row="1" Classes="graphHover" Background="Transparent" BorderThickness="0" Padding="8,4" Margin="-3,0,0,0" Cursor="Hand" HorizontalAlignment="Left" CornerRadius="4" VerticalAlignment="Top">
                                                                <Grid ColumnDefinitions="Auto, 15, Auto" RowDefinitions="Auto, Auto">
                                                                    <TextBlock Grid.Row="0" Grid.Column="0" x:Name="lblLocalPortLabel" Text="OPEN LOCAL PORT:" FontSize="10" FontWeight="Bold" Foreground="#A0AEC0" Margin="0,0,0,2"/>
                                                                    <TextBlock Grid.Row="0" Grid.Column="2" x:Name="lblLanPortLabel" Text="OPEN LAN PORT:" FontSize="10" FontWeight="Bold" Foreground="#A0AEC0" Margin="0,0,0,2"/>
                                                                    <TextBlock Grid.Row="1" Grid.Column="0" x:Name="lblLocalIp" FontSize="11" FontWeight="Bold" FontFamily="Consolas" Classes="portHoverText" PointerPressed="CopyIp_PointerPressed" VerticalAlignment="Center"/>
                                                                    <TextBlock Grid.Row="1" Grid.Column="2" x:Name="lblLanIp" FontSize="11" FontWeight="Bold" FontFamily="Consolas" Classes="portHoverText" PointerPressed="CopyIp_PointerPressed" VerticalAlignment="Center"/>
                                                                </Grid>
                                                            </Button>
                                                        </Grid>

                                                        <Button x:Name="btnRefreshPing" Grid.Column="1" Classes="graphHover" Background="Transparent" BorderThickness="0" Padding="8,4" Cursor="Hand" Click="RefreshPing_Click" VerticalAlignment="Top" HorizontalAlignment="Right" HorizontalContentAlignment="Stretch">
                                                            <Grid ColumnDefinitions="Auto,Auto,Auto" Margin="5,0,5,0" VerticalAlignment="Center">
                                                                  
                                                                <StackPanel Grid.Column="0" VerticalAlignment="Center" Spacing="8" Margin="0,0,15,0">
                                                                    <StackPanel HorizontalAlignment="Left">
                                                                        <TextBlock x:Name="lblPingLabel" Text="Ping" FontSize="10" Foreground="#8B949E"/>
                                                                        <TextBlock x:Name="lblPing" Text="0 ms" FontSize="10" Foreground="#8B949E" Margin="0,2,0,0"/>
                                                                    </StackPanel>
                                                                    
                                                                    <StackPanel HorizontalAlignment="Left">
                                                                        <TextBlock x:Name="lblTotalLabel" Text="Total" FontSize="10" Foreground="#8B949E"/>
                                                                        <TextBlock x:Name="lblTotalData" Text="0 MB" FontSize="10" Foreground="#8B949E" Margin="0,2,0,0"/>
                                                                    </StackPanel>
                                                                </StackPanel>

                                                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="8" Margin="0,0,10,0">
                                                                    <StackPanel HorizontalAlignment="Left">
                                                                        <StackPanel Orientation="Horizontal" Spacing="4">
                                                                            <Ellipse Width="8" Height="8" Fill="#4CAF50" VerticalAlignment="Center" Opacity="0.75"/>
                                                                            <TextBlock x:Name="lblDownloadLabel" Text="Download" FontSize="10" Foreground="#8B949E" VerticalAlignment="Center"/>
                                                                        </StackPanel>
                                                                        <TextBlock x:Name="lblDownloadSpeed" Text="0 KB/s" FontSize="10" Foreground="#8B949E" Margin="12,2,0,0"/>
                                                                    </StackPanel>
                                                                    
                                                                    <StackPanel HorizontalAlignment="Left">
                                                                        <StackPanel Orientation="Horizontal" Spacing="4">
                                                                            <Ellipse Width="8" Height="8" Fill="#D32F2F" VerticalAlignment="Center" Opacity="0.75"/>
                                                                            <TextBlock x:Name="lblUploadLabel" Text="Upload" FontSize="10" Foreground="#8B949E" VerticalAlignment="Center"/>
                                                                        </StackPanel>
                                                                        <TextBlock x:Name="lblUploadSpeed" Text="0 KB/s" FontSize="10" Foreground="#8B949E" Margin="12,2,0,0"/>
                                                                    </StackPanel>
                                                                </StackPanel>

                                                                <Canvas Grid.Column="2" Width="150" Height="40" ClipToBounds="True" VerticalAlignment="Center">
                                                                    <Polyline x:Name="graphUpload" Stroke="#D32F2F" StrokeThickness="2" StrokeJoin="Round" Opacity="0.75"/>
                                                                    <Polyline x:Name="graphDownload" Stroke="#4CAF50" StrokeThickness="2" StrokeJoin="Round" Opacity="0.75"/>
                                                                </Canvas>
                                                            </Grid>
                                                        </Button>
                                                    </Grid>
                                                </Border>
                                          </StackPanel>
                                      </Border>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Grid>

                    <Border x:Name="panExpertOverlay" Classes="popupContent" Grid.Column="1" Background="#F2101116" BorderBrush="#2D3748" BorderThickness="1" CornerRadius="12" Margin="-5,10,25,15" ZIndex="400" IsVisible="False" Padding="30,20,30,10" VerticalAlignment="Top"  BoxShadow="0 0 50 1000 #B3000000">
                        <Grid RowDefinitions="Auto,Auto,Auto">
                            <TextBlock x:Name="lblExpertTitle" Grid.Row="0" Text="EXPERT ROUTING CONFIGURATION" FontSize="16" FontWeight="Bold" Foreground="#E2E8F0" Margin="0,0,0,20"/>
                            
                            <Grid Grid.Row="1" ColumnDefinitions="Auto, *, Auto, *" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto" Margin="0">
                                    <TextBlock x:Name="lblHardwareAccel" Grid.Row="0" Grid.Column="0" Text="Hardware Accel:" Foreground="#8B949E" FontSize="11" VerticalAlignment="Center" Margin="0,0,10,10"/>
                                    <ComboBox x:Name="cmbHW" Grid.Row="0" Grid.Column="1" Background="#0A0C0F" Foreground="#E2E8F0" BorderBrush="#3A3F44" BorderThickness="1" CornerRadius="4" Height="26" MinHeight="26" Padding="4,3" FontSize="11" Margin="0,0,20,10" HorizontalAlignment="Stretch">
                                        <ComboBoxItem Content="Disabled"/><ComboBoxItem Content="Enabled"/>
                                    </ComboBox>
                                    
                                    <TextBlock x:Name="lblFascistFirewall" Grid.Row="0" Grid.Column="2" Text="Fascist Firewall:" Foreground="#8B949E" FontSize="11" VerticalAlignment="Center" Margin="0,0,10,10"/>
                                    <ComboBox x:Name="cmbFF" Grid.Row="0" Grid.Column="3" Background="#0A0C0F" Foreground="#E2E8F0" BorderBrush="#3A3F44" BorderThickness="1" CornerRadius="4" Height="26" MinHeight="26" Padding="4,3" FontSize="11" Margin="0,0,0,10" HorizontalAlignment="Stretch">
                                        <ComboBoxItem Content="Disabled"/><ComboBoxItem Content="Enabled"/>
                                    </ComboBox>

                                    <TextBlock x:Name="lblStrictNodes" Grid.Row="1" Grid.Column="0" Text="Strict Nodes:" Foreground="#8B949E" FontSize="11" VerticalAlignment="Center" Margin="0,0,10,10"/>
                                    <ComboBox x:Name="cmbSN" Grid.Row="1" Grid.Column="1" Background="#0A0C0F" Foreground="#E2E8F0" BorderBrush="#3A3F44" BorderThickness="1" CornerRadius="4" Height="26" MinHeight="26" Padding="4,3" FontSize="11" Margin="0,0,20,10" HorizontalAlignment="Stretch">
                                        <ComboBoxItem Content="Disabled"/><ComboBoxItem Content="Enabled"/>
                                    </ComboBox>

                                    <TextBlock Grid.Row="1" Grid.Column="2" Text="CircuitBuildTimeout:" Foreground="#8B949E" FontSize="11" VerticalAlignment="Center" Margin="0,0,10,10"/>
                                    <TextBox x:Name="txtCBT" Grid.Row="1" Grid.Column="3" Background="#0A0C0F" Foreground="#68D391" BorderBrush="#3A3F44" BorderThickness="1" CornerRadius="4" Height="26" MinHeight="26" Padding="4,3" FontFamily="Consolas" FontSize="11" Margin="0,0,0,10"/>

                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="KeepalivePeriod:" Foreground="#8B949E" FontSize="11" VerticalAlignment="Center" Margin="0,0,10,10"/>
                                    <TextBox x:Name="txtKP" Grid.Row="2" Grid.Column="1" Background="#0A0C0F" Foreground="#68D391" BorderBrush="#3A3F44" BorderThickness="1" CornerRadius="4" Height="26" MinHeight="26" Padding="4,3" FontFamily="Consolas" FontSize="11" Margin="0,0,20,10"/>

                                    <TextBlock Grid.Row="2" Grid.Column="2" Text="NewCircuitPeriod:" Foreground="#8B949E" FontSize="11" VerticalAlignment="Center" Margin="0,0,10,10"/>
                                    <TextBox x:Name="txtNCP" Grid.Row="2" Grid.Column="3" Background="#0A0C0F" Foreground="#68D391" BorderBrush="#3A3F44" BorderThickness="1" CornerRadius="4" Height="26" MinHeight="26" Padding="4,3" FontFamily="Consolas" FontSize="11" Margin="0,0,0,10"/>

                                    <TextBlock Grid.Row="3" Grid.Column="0" Text="MaxCircuitDirtiness:" Foreground="#8B949E" FontSize="11" VerticalAlignment="Center" Margin="0,0,10,10"/>
                                    <TextBox x:Name="txtMCD" Grid.Row="3" Grid.Column="1" Background="#0A0C0F" Foreground="#68D391" BorderBrush="#3A3F44" BorderThickness="1" CornerRadius="4" Height="26" MinHeight="26" Padding="4,3" FontFamily="Consolas" FontSize="11" Margin="0,0,20,10"/>

                                    <TextBlock Grid.Row="3" Grid.Column="2" Text="NumEntryGuards:" Foreground="#8B949E" FontSize="11" VerticalAlignment="Center" Margin="0,0,10,10"/>
                                    <TextBox x:Name="txtNEG" Grid.Row="3" Grid.Column="3" Background="#0A0C0F" Foreground="#68D391" BorderBrush="#3A3F44" BorderThickness="1" CornerRadius="4" Height="26" MinHeight="26" Padding="4,3" FontFamily="Consolas" FontSize="11" Margin="0,0,0,10"/>

                                    <TextBlock Grid.Row="4" Grid.Column="0" Text="EntryNodes {us}:" Foreground="#8B949E" FontSize="11" VerticalAlignment="Center" Margin="0,0,10,10"/>
                                    <TextBox x:Name="txtEN" Grid.Row="4" Grid.Column="1" Background="#0A0C0F" Foreground="#68D391" BorderBrush="#3A3F44" BorderThickness="1" CornerRadius="4" Height="26" MinHeight="26" Padding="4,3" FontFamily="Consolas" FontSize="11" Margin="0,0,20,10"/>

                                    <TextBlock Grid.Row="4" Grid.Column="2" Text="ExitNodes {uk},{de}:" Foreground="#8B949E" FontSize="11" VerticalAlignment="Center" Margin="0,0,10,10"/>
                                    <TextBox x:Name="txtExit" Grid.Row="4" Grid.Column="3" Background="#0A0C0F" Foreground="#68D391" BorderBrush="#3A3F44" BorderThickness="1" CornerRadius="4" Height="26" MinHeight="26" Padding="4,3" FontFamily="Consolas" FontSize="11" Margin="0,0,0,10"/>

                                    <TextBlock Grid.Row="5" Grid.Column="0" Text="ExcludeNodes:" Foreground="#8B949E" FontSize="11" VerticalAlignment="Center" Margin="0,0,10,10"/>
                                    <TextBox x:Name="txtExNodes" Grid.Row="5" Grid.Column="1" Background="#0A0C0F" Foreground="#68D391" BorderBrush="#3A3F44" BorderThickness="1" CornerRadius="4" Height="26" MinHeight="26" Padding="4,3" FontFamily="Consolas" FontSize="11" Margin="0,0,20,10"/>

                                    <TextBlock Grid.Row="5" Grid.Column="2" Text="ExcludeExitNodes:" Foreground="#8B949E" FontSize="11" VerticalAlignment="Center" Margin="0,0,10,10"/>
                                    <TextBox x:Name="txtExExit" Grid.Row="5" Grid.Column="3" Background="#0A0C0F" Foreground="#68D391" BorderBrush="#3A3F44" BorderThickness="1" CornerRadius="4" Height="26" MinHeight="26" Padding="4,3" FontFamily="Consolas" FontSize="11" Margin="0,0,0,10"/>

                                    <TextBlock x:Name="lblCustomTorrc" Grid.Row="6" Grid.Column="0" Grid.ColumnSpan="4" Text="Custom Torrc Lines (Advanced - One per line):" Foreground="#8B949E" FontSize="11" VerticalAlignment="Center" Margin="0,5,0,10"/>
                                    <TextBox x:Name="txtRaw" Grid.Row="7" Grid.Column="0" Grid.ColumnSpan="4" Height="60" AcceptsReturn="True" TextWrapping="Wrap" Background="#0A0C0F" Foreground="#68D391" BorderBrush="#3A3F44" BorderThickness="1" CornerRadius="4" FontFamily="Consolas" FontSize="11" ScrollViewer.VerticalScrollBarVisibility="Auto" Margin="0"/>
                                </Grid>
                              <Grid Grid.Row="2" ColumnDefinitions="*,1,*" Margin="0,10,0,0" HorizontalAlignment="Right" Width="150">
                                <Button x:Name="btnExpertSave" Click="btnExpertSave_Click" Grid.Column="0" Content="SAVE" FontSize="11" FontWeight="Bold" Foreground="#A0AEC0" Background="Transparent" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" VerticalAlignment="Stretch" Cursor="Hand" BorderThickness="0" CornerRadius="0" Padding="0,8">
                                    <Button.Styles>
                                        <Style Selector="Button:pointerover /template/ ContentPresenter">
                                            <Setter Property="Background" Value="#2AFFFFFF"/>
                                        </Style>
                                    </Button.Styles>
                                </Button>
                                <Border Grid.Column="1" Background="#2D3748"/>
                                <Button x:Name="btnExpertCancel" Click="btnExpertCancel_Click" Grid.Column="2" Content="CANCEL" FontSize="11" FontWeight="Bold" Foreground="#A0AEC0" Background="Transparent" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" VerticalAlignment="Stretch" Cursor="Hand" BorderThickness="0" CornerRadius="0" Padding="0,8">
                                    <Button.Styles>
                                        <Style Selector="Button:pointerover /template/ ContentPresenter">
                                            <Setter Property="Background" Value="#2AFFFFFF"/>
                                        </Style>
                                    </Button.Styles>
                                </Button>
                            </Grid>
                        </Grid>
                    </Border>
                    
                    <Border x:Name="panSettingsOverlay" Classes="popupContent" Grid.Column="1" Background="#F2101116" BorderBrush="#2D3748" BorderThickness="1" CornerRadius="12" Margin="-5,10,25,15" ZIndex="400" IsVisible="False" Padding="0" VerticalAlignment="Top" MaxHeight="460" BoxShadow="0 0 50 1000 #B3000000">
                        <Grid>
                            <Border x:Name="SettingsLightDismiss" Background="#01000000" IsVisible="False" PointerPressed="SettingsLightDismiss_PointerPressed" ZIndex="500"/>
                            <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto" Margin="20,15,0,10" Padding="0,0,20,0">
                                <StackPanel Spacing="10">
                                    <TextBlock x:Name="lblSectionStartup" Text="START-UP" FontSize="11" FontWeight="SemiBold" Foreground="#8B949E" LetterSpacing="1" Margin="5,0,0,0"/>
                                    <Grid ColumnDefinitions="*, *" RowDefinitions="Auto, Auto">
                                        <Border Grid.Row="0" Grid.Column="0" Background="#101112" BorderBrush="#2D3748" BorderThickness="1" CornerRadius="8" Padding="12,8" Margin="0,0,5,8">
                                            <Grid x:Name="panLaunchOnStartup" ColumnDefinitions="Auto, *, Auto" MinHeight="36" Background="Transparent">
                                                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                                                    <PathIcon Data="M13.13 22.19L11.5 18.36C13.07 17.78 14.54 17 15.9 16.09L13.13 22.19M5.64 12.5L1.81 10.87L7.91 8.1C7 9.46 6.22 10.93 5.64 12.5M21.61 2.39C21.61 2.39 16.66 .269 11 5.93C8.81 8.12 7.5 10.53 6.65 12.64L3.05 11.33L1.58 12.8L6.47 14.86L3.92 17.41L5 18.5L7.55 15.95L9.61 20.84L11.08 19.37L9.77 15.77C11.88 14.92 14.29 13.61 16.48 11.42C22.14 5.76 20.02 .81 20.02 .81L21.61 2.39Z" Width="14" Height="14" Foreground="#8B949E"/>
                                                    <TextBlock x:Name="lblLaunchOnStartup" Text="LAUNCH ON START-UP" FontSize="11" FontWeight="SemiBold" Foreground="#8B949E" LetterSpacing="1" VerticalAlignment="Center"/>
                                                </StackPanel>
                                                <ToggleSwitch x:Name="btnBootTog" Grid.Column="2" IsCheckedChanged="SettingTog_CheckedChanged" OnContent="{x:Null}" OffContent="{x:Null}" VerticalAlignment="Center"/>
                                            </Grid>
                                        </Border>
                                        <Border Grid.Row="0" Grid.Column="1" Background="#101112" BorderBrush="#2D3748" BorderThickness="1" CornerRadius="8" Padding="12,8" Margin="5,0,0,8">
                                            <Grid x:Name="panAutoConnect" ColumnDefinitions="Auto, *, Auto" MinHeight="36" Background="Transparent">
                                                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                                                    <PathIcon Data="M3.9 12c0-1.71 1.39-3.1 3.1-3.1h4V7H7c-2.76 0-5 2.24-5 5s2.24 5 5 5h4v-1.9H7c-1.71 0-3.1-1.39-3.1-3.1zM8 13h8v-2H8v2zm9-6h-4v1.9h4c1.71 0 3.1 1.39 3.1 3.1s-1.39 3.1-3.1 3.1h-4V17h4c2.76 0 5-2.24 5-5s-2.24-5-5-5z" Width="14" Height="14" Foreground="#8B949E"/>
                                                    <TextBlock x:Name="lblAutoConnect" Text="AUTO-CONNECT" FontSize="11" FontWeight="SemiBold" Foreground="#8B949E" LetterSpacing="1" VerticalAlignment="Center"/>
                                                </StackPanel>
                                                <ToggleSwitch x:Name="btnAutoTog" Grid.Column="2" IsCheckedChanged="SettingTog_CheckedChanged" OnContent="{x:Null}" OffContent="{x:Null}" VerticalAlignment="Center"/>
                                            </Grid>
                                        </Border>
                                        <Border Grid.Row="1" Grid.Column="0" Background="#101112" BorderBrush="#2D3748" BorderThickness="1" CornerRadius="8" Padding="12,8" Margin="0,0,5,0">
                                            <Grid x:Name="panStartMinimized" ColumnDefinitions="Auto, *, Auto" MinHeight="36" Background="Transparent">
                                                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                                                    <PathIcon Data="M19 13H5v-2h14v2z" Width="14" Height="14" Foreground="#8B949E"/>
                                                    <TextBlock x:Name="lblStartMinimized" Text="START MINIMIZED" FontSize="11" FontWeight="SemiBold" Foreground="#8B949E" LetterSpacing="1" VerticalAlignment="Center"/>
                                                </StackPanel>
                                                <ToggleSwitch x:Name="btnStartMinTog" Grid.Column="2" IsCheckedChanged="SettingTog_CheckedChanged" OnContent="{x:Null}" OffContent="{x:Null}" VerticalAlignment="Center"/>
                                            </Grid>
                                        </Border>
                                        <Border Grid.Row="1" Grid.Column="1" Background="#101112" BorderBrush="#2D3748" BorderThickness="1" CornerRadius="8" Padding="12,8" Margin="5,0,0,0">
                                            <Grid x:Name="panMinimizeToTray" ColumnDefinitions="Auto, *, Auto" MinHeight="36" Background="Transparent">
                                                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                                                    <PathIcon Data="M21 3H3c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h18c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm0 16H3V5h18v14zm-10-7h2v3h-2z" Width="14" Height="14" Foreground="#8B949E"/>
                                                    <TextBlock x:Name="lblMinimizeToTray" Text="MINIMIZE TO TRAY" FontSize="11" FontWeight="SemiBold" Foreground="#8B949E" LetterSpacing="1" VerticalAlignment="Center"/>
                                                </StackPanel>
                                                <ToggleSwitch x:Name="btnTrayTog" Grid.Column="2" IsCheckedChanged="SettingTog_CheckedChanged" OnContent="{x:Null}" OffContent="{x:Null}" VerticalAlignment="Center"/>
                                            </Grid>
                                        </Border>
                                    </Grid>
                                    
                                    <TextBlock x:Name="lblSectionConnection" Text="CONNECTION" FontSize="11" FontWeight="SemiBold" Foreground="#8B949E" LetterSpacing="1" Margin="5,15,0,0"/>
                                    <StackPanel Spacing="8">
                                        
                                        <StackPanel Spacing="0">
                                            <Border x:Name="panXrayExitNodeToggle" Background="#101112" BorderBrush="#2D3748" BorderThickness="1" CornerRadius="8" Padding="0">
                                                <Button x:Name="btnXrayExitNodeToggle" Classes="optBtn" CornerRadius="8" BorderThickness="0" Background="Transparent" Padding="12,8" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Click="btnXrayExitNodeToggle_Click">
                                                    <Grid ColumnDefinitions="Auto, *, Auto, Auto" MinHeight="36">
                                                        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                                                            <PathIcon Data="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 17.93c-3.95-.49-7-3.85-7-7.93 0-.62.08-1.21.21-1.79L9 15v1c0 1.1.9 2 2 2v1.93zm6.9-2.54c-.26-.81-1-1.39-1.9-1.39h-1v-3c0-.55-.45-1-1-1H8v-2h2c.55 0 1-.45 1-1V7h2c1.1 0 2-.9 2-2v-.41c2.93 1.19 5 4.06 5 7.41 0 2.08-.8 3.97-2.1 5.39z" Width="14" Height="14" Foreground="#8B949E"/>
                                                            <StackPanel Orientation="Horizontal" Spacing="3" VerticalAlignment="Center">
                                                                <TextBlock x:Name="lblCustomXrayExit" Classes="settingTitle" Text="CUSTOM XRAY EXIT-NODE" FontSize="11" FontWeight="SemiBold" LetterSpacing="1" VerticalAlignment="Center" ToolTip.Tip="Use a personal Xray server as your exit node after Tor. Path: you Ã¢â€ â€™ Tor Ã¢â€ â€™ your Xray server Ã¢â€ â€™ internet. Websites see your Xray server's IP, not Tor's. Paste outbound JSON or import a share link (VLESS, VMess, Trojan, SS). Only ports 80 and 443 work over Tor; REALITY, KCP, and QUIC are blocked."/>
                                                            </StackPanel>
                                                        </StackPanel>
                                                        <ToggleSwitch Grid.Column="2" x:Name="togXrayExitNode" OnContent="{x:Null}" OffContent="{x:Null}" HorizontalAlignment="Right" VerticalAlignment="Center" MinWidth="40" Margin="0,0,10,0" IsCheckedChanged="togXrayExitNode_IsCheckedChanged"/>
                                                        <PathIcon x:Name="icoXrayExitNodeExpander" Grid.Column="3" Data="M7.41 8.59L12 13.17l4.59-4.58L18 10l-6 6-6-6 1.41-1.41z" Width="12" Height="12" Foreground="#8B949E" VerticalAlignment="Center">
                                                            <PathIcon.Transitions>
                                                                <Transitions>
                                                                    <DoubleTransition Property="RotateTransform.Angle" Duration="0:0:0.2" Easing="CubicEaseOut"/>
                                                                </Transitions>
                                                            </PathIcon.Transitions>
                                                        </PathIcon>
                                                    </Grid>
                                                </Button>
                                            </Border>
                                            <Border x:Name="panXrayExitNode" Background="#0A0B0E" BorderBrush="#2D3748" BorderThickness="1,0,1,1" CornerRadius="0,0,8,8" MaxHeight="0" Opacity="0" ClipToBounds="True">
                                                <Border.Transitions>
                                                    <Transitions>
                                                        <DoubleTransition Property="MaxHeight" Duration="0:0:0.3" Easing="CubicEaseOut"/>
                                                        <DoubleTransition Property="Opacity" Duration="0:0:0.3" Easing="CubicEaseOut"/>
                                                    </Transitions>
                                                </Border.Transitions>
                                                <StackPanel Margin="15,15,15,15" Spacing="10">
                                                    <TextBox x:Name="txtXrayJson" TextChanged="txtXrayJson_TextChanged" Height="120" AcceptsReturn="True" TextWrapping="Wrap" Background="#1A1C20" Foreground="#68D391" BorderBrush="#2D3748" BorderThickness="1" FontFamily="Consolas" FontSize="11" CornerRadius="4" VerticalAlignment="Stretch"/>
                                                    
                                                    <Grid ColumnDefinitions="Auto, *">
                                                        <Button Grid.Column="0" x:Name="btnXrayImport" Click="btnXrayImport_Click" Content="IMPORT .JSON" Classes="optBtn" FontSize="10" FontWeight="Bold" Background="#1AFFFFFF" Padding="12,6" VerticalAlignment="Center"/>
                                                        
                                                        <Border Grid.Column="1" Background="#0A0C0F" CornerRadius="3" BorderBrush="#2D3748" BorderThickness="1" HorizontalAlignment="Right" Width="140" Margin="0">
                                                            <Grid ColumnDefinitions="*, 1, *">
                                                                <Button x:Name="btnXraySave" Click="btnXraySave_Click" Grid.Column="0" Content="SAVE" FontSize="10" FontWeight="Bold" Foreground="#A0AEC0" Background="Transparent" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" VerticalAlignment="Stretch" Cursor="Hand" BorderThickness="0" CornerRadius="3,0,0,3">
                                                                    <Button.Styles>
                                                                        <Style Selector="Button:pointerover /template/ ContentPresenter">
                                                                            <Setter Property="Background" Value="#2AFFFFFF"/>
                                                                        </Style>
                                                                    </Button.Styles>
                                                            </Button>
                                                            <Border Grid.Column="1" Background="#2D3748"/>
                                                            <Button x:Name="btnXrayCancel" Click="btnXrayCancel_Click" Grid.Column="2" Content="CANCEL" FontSize="10" FontWeight="Bold" Foreground="#A0AEC0" Background="Transparent" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" VerticalAlignment="Stretch" Cursor="Hand" BorderThickness="0" CornerRadius="0,3,3,0">
                                                                <Button.Styles>
                                                                    <Style Selector="Button:pointerover /template/ ContentPresenter">
                                                                        <Setter Property="Background" Value="#2AFFFFFF"/>
                                                                    </Style>
                                                                </Button.Styles>
                                                            </Button>
                                                        </Grid>
                                                    </Border>
                                                    </Grid>
                                                </StackPanel>
                                            </Border>
                                        </StackPanel>
                                        <StackPanel Spacing="0">
                                            <Border x:Name="panOutboundToggle" Background="#101112" BorderBrush="#2D3748" BorderThickness="1" CornerRadius="8" Padding="0">
                                                <Button x:Name="btnOutboundToggle" Classes="optBtn" CornerRadius="8" BorderThickness="0" Background="Transparent" Padding="12,8" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Click="btnOutboundToggle_Click">
                                                    <Grid ColumnDefinitions="Auto, *, Auto, Auto" MinHeight="36">
                                                        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                                                            <PathIcon Data="M21 16v-2l-8-5V3.5c0-.83-.67-1.5-1.5-1.5S10 2.67 10 3.5V9l-8 5v2l8-2.5V19l-2 1.5V22l3.5-1 3.5 1v-1.5L13 19v-5.5l8 2.5z" Width="14" Height="14" Foreground="#8B949E"/>
                                                            <StackPanel Orientation="Horizontal" Spacing="3" VerticalAlignment="Center">
                                                                <TextBlock x:Name="lblOutboundProxySetting" Classes="settingTitle" Text="OUTBOUND PROXY" FontSize="11" FontWeight="SemiBold" LetterSpacing="1" VerticalAlignment="Center" ToolTip.Tip="Send Tor's own connection to the network through an external SOCKS5 or HTTPS proxy. Use this when Tor is blocked and you need a proxy just to reach guard nodes. This affects how Tor boots upÃ¢â‚¬â€not which country your browsing exits from."/>
                                                            </StackPanel>
                                                        </StackPanel>
                                                        <ToggleSwitch Grid.Column="2" x:Name="togOutboundProxy" OnContent="{x:Null}" OffContent="{x:Null}" HorizontalAlignment="Right" VerticalAlignment="Center" MinWidth="40" Margin="0,0,10,0" IsCheckedChanged="togOutboundProxy_IsCheckedChanged"/>
                                                        <PathIcon x:Name="icoOutboundExpander" Grid.Column="3" Data="M7.41 8.59L12 13.17l4.59-4.58L18 10l-6 6-6-6 1.41-1.41z" Width="12" Height="12" Foreground="#8B949E" VerticalAlignment="Center">
                                                            <PathIcon.Transitions>
                                                                <Transitions>
                                                                    <DoubleTransition Property="RotateTransform.Angle" Duration="0:0:0.2" Easing="CubicEaseOut"/>
                                                                </Transitions>
                                                            </PathIcon.Transitions>
                                                        </PathIcon>
                                                    </Grid>
                                                </Button>
                                            </Border>
                                            <Border x:Name="panOutboundProxy" Background="#0A0B0E" BorderBrush="#2D3748" BorderThickness="1,0,1,1" CornerRadius="0,0,8,8" MaxHeight="0" Opacity="0" ClipToBounds="True">
                                                <Border.Transitions>
                                                    <Transitions>
                                                        <DoubleTransition Property="MaxHeight" Duration="0:0:0.3" Easing="CubicEaseOut"/>
                                                        <DoubleTransition Property="Opacity" Duration="0:0:0.3" Easing="CubicEaseOut"/>
                                                    </Transitions>
                                                </Border.Transitions>
                                                <StackPanel Margin="15,15,15,15" Spacing="10">
                                                    <Grid ColumnDefinitions="Auto,*,Auto">
                                                        <StackPanel Grid.Column="0" Spacing="5" Margin="0,0,10,0">
                                                            <TextBlock x:Name="lblOutboundType" Text="TYPE" FontSize="10" FontWeight="Bold" Foreground="#A0AEC0"/>
                                                            <ComboBox x:Name="cmbOutboundType" Width="100" MinHeight="26" Height="26" FontSize="11" VerticalContentAlignment="Center" SelectedIndex="0">
                                                                <ComboBoxItem Content="SOCKS5"/>
                                                                <ComboBoxItem Content="HTTPS"/>
                                                            </ComboBox>
                                                        </StackPanel>
                                                        <StackPanel Grid.Column="1" Spacing="5" Margin="0,0,10,0">
