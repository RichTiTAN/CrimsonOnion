                                                            <StackPanel Orientation="Horizontal" Spacing="3" VerticalAlignment="Center">
                                                                <TextBlock x:Name="lblAdapterBindingTitle" Classes="settingTitle" Text="BIND ADAPTER" FontSize="11" FontWeight="SemiBold" LetterSpacing="1" VerticalAlignment="Center" ToolTip.Tip="Forces all Tor traffic to exclusively exit through the selected network adapter."/>
                                                            </StackPanel>
