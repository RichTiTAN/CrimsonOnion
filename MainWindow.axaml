                                                    <Grid ColumnDefinitions="*, Auto">
                                                        <ComboBox Grid.Column="0" x:Name="cmbAdapters" HorizontalAlignment="Stretch" Margin="0,0,10,0" MinHeight="26" Height="26" FontSize="11" VerticalContentAlignment="Center" PlaceholderText="Select an adapter..." SelectionChanged="cmbAdapters_SelectionChanged"/>
                                                        <Button Grid.Column="1" x:Name="btnScanAdapters" Click="btnScanAdapters_Click" Content="SCAN" Classes="optBtn" FontSize="10" FontWeight="Bold" Background="#1AFFFFFF" Padding="12,6" VerticalAlignment="Center"/>
                                                    </Grid>
                                                </StackPanel>
