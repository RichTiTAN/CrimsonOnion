                                                            <PathIcon x:Name="icoLanExpander" Data="M7.41 8.59L12 13.17l4.59-4.58L18 10l-6 6-6-6 1.41-1.41z" Width="12" Height="12" Foreground="#8B949E" VerticalAlignment="Center">
                                                                <PathIcon.Transitions>
