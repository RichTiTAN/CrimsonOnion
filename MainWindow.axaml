                                        <StackPanel Spacing="0">
                                            <Border x:Name="panAdapterBindingToggle" Background="#101112" BorderBrush="#2D3748" BorderThickness="1" CornerRadius="8" Padding="0">
                                                <Button x:Name="btnAdapterBindingToggle" Classes="optBtn" CornerRadius="8" BorderThickness="0" Background="Transparent" Padding="12,8" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Click="btnAdapterBindingToggle_Click">
                                                    <Grid ColumnDefinitions="Auto, *, Auto, Auto" MinHeight="36">
