                                                        </StackPanel>
                                                        <ToggleSwitch Grid.Column="1" x:Name="togOutboundAuth" OnContent="{x:Null}" OffContent="{x:Null}" HorizontalAlignment="Right" VerticalAlignment="Center" MinWidth="40" IsCheckedChanged="togOutboundAuth_IsCheckedChanged"/>
                                                    </Grid>
                                                    
                                                    <Border x:Name="panOutboundAuth" MaxHeight="0" Opacity="0" ClipToBounds="True">
                                                        <Border.Transitions>
