        public static string TtCustomXray   => IsPersian ? "Ø§Ø² Ø³Ø±ÙˆØ± Ø´Ø®ØµÛŒ Xray Ø®ÙˆØ¯ Ø¨Ù‡ Ø¹Ù†ÙˆØ§Ù† Ù†ÙˆØ¯ Ø®Ø±ÙˆØ¬ÛŒ Ø¨Ø¹Ø¯ Ø§Ø² Tor Ø§Ø³ØªÙØ§Ø¯Ù‡ Ú©Ù†ÛŒØ¯. Ù…Ø³ÛŒØ±: Ø´Ù…Ø§ -> Tor -> Ø³Ø±ÙˆØ± Xray Ø´Ù…Ø§ -> Ø§ÛŒÙ†ØªØ±Ù†Øª. Ø³Ø§ÛŒØªâ€ŒÙ‡Ø§ IP Ø³Ø±ÙˆØ± Xray Ø´Ù…Ø§ Ø±Ø§ Ù…ÛŒâ€ŒØ¨ÛŒÙ†Ù†Ø¯ Ù†Ù‡ Tor. ÛŒÚ© Ø®Ø±ÙˆØ¬ÛŒ JSON Ø¬Ø§ÛŒÚ¯Ø°Ø§Ø±ÛŒ Ú©Ù†ÛŒØ¯ ÛŒØ§ ÛŒÚ© Ù„ÛŒÙ†Ú© Ø§Ø´ØªØ±Ø§Ú©â€ŒÚ¯Ø°Ø§Ø±ÛŒ (VLESS, VMess, Trojan, SS) ÙˆØ§Ø±Ø¯ Ú©Ù†ÛŒØ¯. ÙÙ‚Ø· Ù¾ÙˆØ±Øªâ€ŒÙ‡Ø§ÛŒ 80 Ùˆ 443 Ø§Ø² Ø·Ø±ÛŒÙ‚ Tor Ú©Ø§Ø± Ù…ÛŒâ€ŒÚ©Ù†Ù†Ø¯Ø› REALITY, KCP Ùˆ QUIC Ù…Ø³Ø¯ÙˆØ¯ Ù‡Ø³ØªÙ†Ø¯." : "Use a personal Xray server as your exit node after Tor. Path: you â†’ Tor â†’ your Xray server â†’ internet. Websites see your Xray server's IP, not Tor's. Paste outbound JSON or import a share link (VLESS, VMess, Trojan, SS). Only ports 80 and 443 work over Tor; REALITY, KCP, and QUIC are blocked.";
        public static string TtOutboundProxy => IsPersian ? "Ø§ØªØµØ§Ù„ Ø®ÙˆØ¯ Tor Ø¨Ù‡ Ø´Ø¨Ú©Ù‡ Ø±Ø§ Ø§Ø² Ø·Ø±ÛŒÙ‚ ÛŒÚ© Ù¾Ø±ÙˆÚ©Ø³ÛŒ Ø®Ø§Ø±Ø¬ÛŒ SOCKS5 ÛŒØ§ HTTPS Ø§Ø±Ø³Ø§Ù„ Ú©Ù†ÛŒØ¯. Ø§Ø² Ø§ÛŒÙ† Ú¯Ø²ÛŒÙ†Ù‡ Ø²Ù…Ø§Ù†ÛŒ Ø§Ø³ØªÙØ§Ø¯Ù‡ Ú©Ù†ÛŒØ¯ Ú©Ù‡ Tor Ù…Ø³Ø¯ÙˆØ¯ Ø§Ø³Øª Ùˆ Ø¨Ø±Ø§ÛŒ Ø±Ø³ÛŒØ¯Ù† Ø¨Ù‡ Ù†ÙˆØ¯Ù‡Ø§ÛŒ Ù†Ú¯Ù‡Ø¨Ø§Ù† Ø¨Ù‡ Ù¾Ø±ÙˆÚ©Ø³ÛŒ Ù†ÛŒØ§Ø² Ø¯Ø§Ø±ÛŒØ¯. Ø§ÛŒÙ† Ø±ÙˆÛŒ Ù†Ø­ÙˆÙ‡ Ø§ØªØµØ§Ù„ Tor ØªØ£Ø«ÛŒØ± Ù…ÛŒâ€ŒÚ¯Ø°Ø§Ø±Ø¯ØŒ Ù†Ù‡ Ø§ÛŒÙ†Ú©Ù‡ Ù…Ø±ÙˆØ± Ø´Ù…Ø§ Ø§Ø² Ú©Ø¯Ø§Ù… Ú©Ø´ÙˆØ± Ø®Ø§Ø±Ø¬ Ù…ÛŒâ€ŒØ´ÙˆØ¯." : "Send Tor's own connection to the network through an external SOCKS5 or HTTPS proxy. Use this when Tor is blocked and you need a proxy just to reach guard nodes. This affects how Tor boots upâ€”not which country your browsing exits from.";
        public static string TtDnsSettings  => IsPersian ? "Ø­Ù„â€ŒÙˆÙØµÙ„ DNS Ø§Ø² Ø·Ø±ÛŒÙ‚ DNS-over-HTTPS (DoH) Ø±Ù…Ø²Ú¯Ø°Ø§Ø±ÛŒâ€ŒØ´Ø¯Ù‡ Ø¨Ù‡ Ø¬Ø§ÛŒ Ú©ÙˆØ¦Ø±ÛŒâ€ŒÙ‡Ø§ÛŒ Ù…ØªÙ†ÛŒ. Ú©Ø§Ù‡Ø´ Ù†Ø´Øª DNS Ùˆ Ø³Ø§Ù†Ø³ÙˆØ±. ÛŒÚ© Ø§Ø±Ø§Ø¦Ù‡â€ŒØ¯Ù‡Ù†Ø¯Ù‡ Ø§Ù†ØªØ®Ø§Ø¨ Ú©Ù†ÛŒØ¯ ÛŒØ§ ÛŒÚ© URL Ø³ÙØ§Ø±Ø´ÛŒ DoH ÙˆØ§Ø±Ø¯ Ú©Ù†ÛŒØ¯Ø› Ø¯Ø± Ø­Ø§Ù„Øª Ù¾Ø±ÙˆÚ©Ø³ÛŒ (Xray) Ùˆ Ø­Ø§Ù„Øª VPN (sing-box) Ø§Ø¹Ù…Ø§Ù„ Ù…ÛŒâ€ŒØ´ÙˆØ¯." : "Resolve DNS through encrypted DNS-over-HTTPS (DoH) instead of plaintext queries. Reduces DNS leaks and censorship. Pick a provider or enter a custom DoH URL; applies in proxy mode (Xray) and VPN mode (sing-box).";
        public static string TtAdBlocker    => IsPersian ? "Ù…Ø³Ø¯ÙˆØ¯ Ú©Ø±Ø¯Ù† Ø¯Ø±Ø®ÙˆØ§Ø³Øªâ€ŒÙ‡Ø§ Ø¨Ù‡ Ø¯Ø§Ù…Ù†Ù‡â€ŒÙ‡Ø§ÛŒ Ø´Ù†Ø§Ø®ØªÙ‡â€ŒØ´Ø¯Ù‡ ØªØ¨Ù„ÛŒØºØ§Øª Ùˆ Ø±Ø¯ÛŒØ§Ø¨â€ŒÙ‡Ø§ Ù‚Ø¨Ù„ Ø§Ø² Ø®Ø±ÙˆØ¬ Ø§Ø² Ø±Ø§ÛŒØ§Ù†Ù‡ Ø´Ù…Ø§. Xray Ø¯Ø§Ù…Ù†Ù‡â€ŒÙ‡Ø§ÛŒ Ù…Ø·Ø§Ø¨Ù‚ Ø±Ø§ Ø¨Ù‡ ÛŒÚ© Ø®Ø±ÙˆØ¬ÛŒ Ù†Ø§Ù…Ø¹ØªØ¨Ø± (blackhole) Ù‡Ø¯Ø§ÛŒØª Ù…ÛŒâ€ŒÚ©Ù†Ø¯. ÙÙ‚Ø· Ø¨Ø± ØªØ±Ø§ÙÛŒÚ© Ø¹Ø¨ÙˆØ±ÛŒ Ø§Ø² Ù¾Ø±ÙˆÚ©Ø³ÛŒ Ù…Ø­Ù„ÛŒ ØªØ£Ø«ÛŒØ± Ù…ÛŒâ€ŒÚ¯Ø°Ø§Ø±Ø¯ØŒ Ù†Ù‡ Ø¨Ø±Ù†Ø§Ù…Ù‡â€ŒÙ‡Ø§ÛŒÛŒ Ú©Ù‡ Ø§Ø² Ø§Ø³Ù¾Ù„ÛŒØª ØªØ§Ù†Ù„ Ø¹Ø¨ÙˆØ± Ù†Ù…ÛŒâ€ŒÚ©Ù†Ù†Ø¯." : "Drop requests to known ad and tracker domains before they leave your PC. Xray routes matching domains to a blackhole outbound. Only affects traffic going through the local proxyâ€”not apps on split-tunnel bypass.";
        public static string TtAllowLan     => IsPersian ? "Ø¨Ù‡ Ø¯Ø³ØªÚ¯Ø§Ù‡â€ŒÙ‡Ø§ÛŒ Ø¯ÛŒÚ¯Ø± Ø¯Ø± Ø´Ø¨Ú©Ù‡ Ø®ÙˆØ¯ Ø§Ø¬Ø§Ø²Ù‡ Ø¯Ù‡ÛŒØ¯ Ø§Ø² Ø§ÛŒÙ† Ø±Ø§ÛŒØ§Ù†Ù‡ Ø¨Ù‡ Ø¹Ù†ÙˆØ§Ù† Ù¾Ø±ÙˆÚ©Ø³ÛŒ Ø§Ø³ØªÙØ§Ø¯Ù‡ Ú©Ù†Ù†Ø¯. ÙˆÙ‚ØªÛŒ Ø±ÙˆØ´Ù† Ø§Ø³ØªØŒ Ù¾Ø±ÙˆÚ©Ø³ÛŒ Ù…Ø­Ù„ÛŒ Ø±ÙˆÛŒ ØªÙ…Ø§Ù… Ø±Ø§Ø¨Ø·â€ŒÙ‡Ø§ (0.0.0.0) Ú¯ÙˆØ´ Ù…ÛŒâ€ŒØ¯Ù‡Ø¯Ø› ÙˆÙ‚ØªÛŒ Ø®Ø§Ù…ÙˆØ´ Ø§Ø³ØªØŒ ÙÙ‚Ø· Ù‡Ù…ÛŒÙ† Ø¯Ø³ØªÚ¯Ø§Ù‡ (127.0.0.1) Ù…ÛŒâ€ŒØªÙˆØ§Ù†Ø¯ Ù…ØªØµÙ„ Ø´ÙˆØ¯. ÙÙ‚Ø· Ø¯Ø± Ø´Ø¨Ú©Ù‡â€ŒÙ‡Ø§ÛŒÛŒ Ú©Ù‡ Ø¨Ù‡ Ø¢Ù†Ù‡Ø§ Ø§Ø¹ØªÙ…Ø§Ø¯ Ø¯Ø§Ø±ÛŒØ¯ Ø±ÙˆØ´Ù† Ú©Ù†ÛŒØ¯." : "Let other devices on your network use this PC as a proxy. When on, the local proxy listens on all interfaces (0.0.0.0); when off, only this machine (127.0.0.1) can connect. Turn on only on networks you trust.";
        public static string TtLanguage     => IsPersian ? "ØªØºÛŒÛŒØ± Ø²Ø¨Ø§Ù† Ø¨Ø±Ù†Ø§Ù…Ù‡. Ø¨Ø±Ø§ÛŒ Ø§Ø¹Ù…Ø§Ù„ Ú©Ø§Ù…Ù„ ØªØºÛŒÛŒØ±Ø§Øª Ù…Ù…Ú©Ù† Ø§Ø³Øª Ù†ÛŒØ§Ø² Ø¨Ù‡ Ø¨Ø§Ø² Ú©Ø±Ø¯Ù† Ù…Ø¬Ø¯Ø¯ Ø¨Ø±Ù†Ø§Ù…Ù‡ Ø¨Ø§Ø´Ø¯." : "Change the application language. Reopening the app may be required for all changes to take effect.";
        public static string TtDebugMode    => IsPersian ? "Ù†Ù…Ø§ÛŒØ´ Ù¾Ù†Ø¬Ø±Ù‡â€ŒÙ‡Ø§ÛŒ Ú©Ù†Ø³ÙˆÙ„ Ø¨Ø±Ø§ÛŒ TorØŒ XrayØŒ HAProxy Ùˆ sing-box Ø¨Ù‡ Ø¬Ø§ÛŒ Ù¾Ù†Ù‡Ø§Ù† Ú©Ø±Ø¯Ù† Ø¢Ù†Ù‡Ø§. Ø¨Ø±Ø§ÛŒ Ø®ÙˆØ§Ù†Ø¯Ù† Ù„Ø§Ú¯â€ŒÙ‡Ø§ÛŒ Ø²Ù†Ø¯Ù‡ Ù‡Ù†Ú¯Ø§Ù… Ø¹Ø¯Ù… Ø§ØªØµØ§Ù„ Ù…ÙÛŒØ¯ Ø§Ø³Øª. ØªØ£Ø«ÛŒØ±ÛŒ Ø¨Ø± Ù…Ø³ÛŒØ±ÛŒØ§Ø¨ÛŒ ÛŒØ§ Ø§Ù…Ù†ÛŒØª Ù†Ø¯Ø§Ø±Ø¯ØŒ ÙÙ‚Ø· Ø¨Ø±Ø§ÛŒ Ù†Ù…Ø§ÛŒØ´ Ø§Ø³Øª." : "Show console windows for Tor, Xray, HAProxy, and sing-box instead of hiding them. Helpful for reading live logs when something fails to connect. Does not change routing or securityâ€”only visibility.";
        
