<Window x:Class="CrimsonOnion.Dialogs.DirectRulesDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SPLIT TUNNELING AND PRIVACY ENGINE" Height="385" Width="480"
        WindowStartupLocation="CenterOwner" Background="Transparent" Foreground="#E2E8F0"
        ResizeMode="NoResize" FontFamily="Segoe UI" ShowInTaskbar="False"
        WindowStyle="None" AllowsTransparency="True">
    <Window.Resources>
        <SolidColorBrush x:Key="BgPanel"    Color="#121417"/>
        <SolidColorBrush x:Key="BgInput"    Color="#0A0C0F"/>
        <SolidColorBrush x:Key="BorderMain" Color="#2D3748"/>
        <SolidColorBrush x:Key="TextMain"   Color="#E2E8F0"/>
        <SolidColorBrush x:Key="TextMuted"  Color="#A0AEC0"/>
        <SolidColorBrush x:Key="TextGreen"  Color="#68D391"/>
        <SolidColorBrush x:Key="ColorOk"    Color="#4E7A5E"/>
        <SolidColorBrush x:Key="ColorHover" Color="#5F9774"/>
        <Style TargetType="Button">
            <Setter Property="Background" Value="#3A3F44"/>
            <Setter Property="Foreground" Value="{StaticResource TextMain}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="#4A5568"/></Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="Button" x:Key="SaveButton" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="{StaticResource ColorOk}"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="{StaticResource ColorHover}"/></Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>
    <Canvas>
        <Border Name="MainBorder" Canvas.Left="12" Canvas.Top="12" Width="450" Height="361"
                Background="{StaticResource BgPanel}" CornerRadius="8"
                BorderBrush="{StaticResource BorderMain}" BorderThickness="1">
            <Grid>
                <Canvas>
                    <TextBlock Text="SPLIT TUNNELING AND PRIVACY ENGINE" Canvas.Left="15" Canvas.Top="12"
                               FontSize="10" Foreground="{StaticResource TextMuted}" FontWeight="Bold"/>

                    <Border Name="panSplitToggle" Canvas.Left="15" Canvas.Top="35" Width="420" Height="26"
                            BorderBrush="{StaticResource BorderMain}" BorderThickness="1" CornerRadius="4"
                            Background="{StaticResource BgInput}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="139"/>
                                <ColumnDefinition Width="1"/>
                                <ColumnDefinition Width="139"/>
                                <ColumnDefinition Width="1"/>
                                <ColumnDefinition Width="140"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="SPLIT TUNNELING" FontSize="10" FontWeight="Bold"
                                       Foreground="{StaticResource TextMuted}" HorizontalAlignment="Center"
                                       VerticalAlignment="Center" Margin="0,-1,0,0"/>
                            <Rectangle Grid.Column="1" Fill="{StaticResource BorderMain}"/>
                            <Button Name="btnModeExclusive" Grid.Column="2" Content="EXCLUSIVE"
                                    FontSize="10" FontWeight="Bold" Foreground="#E2E8F0" BorderThickness="0" Background="Transparent">
                                <Button.ToolTip>
                                    <ToolTip Content="Selected apps, IPs and domains bypass Tor" Background="#1A202C" Foreground="#E2E8F0" BorderBrush="#2D3748"/>
                                </Button.ToolTip>
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="bg" Background="{TemplateBinding Background}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="bg" Property="Background" Value="#25FFFFFF"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                            <Rectangle Grid.Column="3" Fill="{StaticResource BorderMain}"/>
                            <Button Name="btnModeInclusive" Grid.Column="4" Content="INCLUSIVE"
                                    FontSize="10" FontWeight="Bold" Foreground="#E2E8F0" BorderThickness="0" Background="Transparent">
                                <Button.ToolTip>
                                    <ToolTip Content="Only selected apps, IPs and domains go through Tor" Background="#1A202C" Foreground="#E2E8F0" BorderBrush="#2D3748"/>
                                </Button.ToolTip>
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="bg" Background="{TemplateBinding Background}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="bg" Property="Background" Value="#25FFFFFF"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </Grid>
                    </Border>

                    <Canvas Name="cvsConfig" Canvas.Left="0" Canvas.Top="75" Visibility="Visible">
                        <TextBlock Name="lblDomains" Canvas.Left="15" Canvas.Top="0" FontSize="11"
                                   Foreground="{StaticResource TextMain}"
                                   Text="Domains or IPs to bypass Tor (Comma Separated | Proxy Mode):"/>
                        <TextBox Name="txtDomains" Canvas.Left="15" Canvas.Top="20" Width="420" Height="45"
                                 Background="{StaticResource BgInput}" Foreground="{StaticResource TextGreen}"
                                 BorderBrush="{StaticResource BorderMain}" BorderThickness="1"
                                 TextWrapping="Wrap" Padding="5" FontSize="11" FontFamily="Consolas"/>
                        <TextBlock Name="lblApps" Canvas.Left="15" Canvas.Top="80" FontSize="11" Foreground="{StaticResource TextMain}"
                                   Text="Applications to bypass VPN Tunnel (e.g., spotify.exe | VPN Mode):"/>
                        <TextBox Name="txtApps" Canvas.Left="15" Canvas.Top="100" Width="420" Height="45"
                                 Background="{StaticResource BgInput}" Foreground="{StaticResource TextGreen}"
                                 BorderBrush="{StaticResource BorderMain}" BorderThickness="1"
                                 TextWrapping="Wrap" Padding="5" FontSize="11" FontFamily="Consolas"/>
                        <TextBlock Canvas.Left="15" Canvas.Top="160" FontSize="11" Foreground="{StaticResource TextMain}"
                                   Text="Custom Blacklisted Domains to Block Completely (e.g., tiktok.com):"/>
                        <TextBox Name="txtBlock" Canvas.Left="15" Canvas.Top="180" Width="420" Height="45"
                                 Background="{StaticResource BgInput}" Foreground="{StaticResource TextGreen}"
                                 BorderBrush="{StaticResource BorderMain}" BorderThickness="1"
                                 TextWrapping="Wrap" Padding="5" FontSize="11" FontFamily="Consolas"/>
                        <Button Name="btnOk" Content="Save Config" Canvas.Left="245" Canvas.Top="243"
                                Width="90" Height="25" IsDefault="True" Style="{StaticResource SaveButton}"/>
                        <Button Name="btnCancel" Content="Cancel" Canvas.Left="345" Canvas.Top="243"
                                Width="90" Height="25" IsCancel="True"/>
                    </Canvas>
                </Canvas>
                <Button Name="btnCloseDialog" HorizontalAlignment="Right" VerticalAlignment="Top"
                        Margin="0,6,6,0" Width="22" Height="22" Content="&#x2715;"
                        FontSize="10" FontWeight="Bold" Padding="0,-1,0,0">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Foreground" Value="#4A5568"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Cursor" Value="Hand"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="3">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#2D3748"/>
                                    <Setter Property="Foreground" Value="#E2E8F0"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>
        </Border>
    </Canvas>
</Window>
