<Window x:Class="CrimsonOnion.Dialogs.ExpertConfigDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="EXPERT TORRC CONFIGURATION" Height="530" Width="530"
        WindowStartupLocation="CenterOwner" Background="Transparent" Foreground="#E2E8F0"
        ResizeMode="NoResize" FontFamily="Segoe UI" ShowInTaskbar="False"
        WindowStyle="None" AllowsTransparency="True">
    <Window.Resources>
        <SolidColorBrush x:Key="BgPanel"    Color="#121417"/>
        <SolidColorBrush x:Key="BgInput"    Color="#0A0C0F"/>
        <SolidColorBrush x:Key="BorderMain" Color="#2D3748"/>
        <SolidColorBrush x:Key="TextMain"   Color="#E2E8F0"/>
        <SolidColorBrush x:Key="TextMuted"  Color="#A0AEC0"/>
        <SolidColorBrush x:Key="TextGreen"  Color="#68D391"/>
        <SolidColorBrush x:Key="ColorOk"    Color="#4E7A5E"/>
        <SolidColorBrush x:Key="ColorHover" Color="#5F9774"/>
        <Style TargetType="Button">
            <Setter Property="Background" Value="#3A3F44"/>
            <Setter Property="Foreground" Value="{StaticResource TextMain}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="#4A5568"/></Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="Button" x:Key="SaveButton" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="{StaticResource ColorOk}"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="{StaticResource ColorHover}"/></Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="ComboBox" x:Key="DarkComboBox">
            <Setter Property="Foreground" Value="{StaticResource TextMain}"/>
            <Setter Property="Background" Value="{StaticResource BgInput}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderMain}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton Name="ToggleButton" Background="{TemplateBinding Background}"
                                          BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}"
                                          Focusable="False" IsChecked="{Binding Path=IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}" ClickMode="Press">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="4">
                                            <ContentPresenter HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                        </Border>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                                <Path Fill="{StaticResource TextMuted}" Data="M0,0 L4,4 L8,0 Z" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,5,0"/>
                            </ToggleButton>
                            <ContentPresenter Name="ContentSite" IsHitTestVisible="False" Content="{TemplateBinding SelectionBoxItem}"
                                              Margin="8,0,23,2" VerticalAlignment="Center" HorizontalAlignment="Left">
                                <ContentPresenter.Resources>
                                    <Style TargetType="TextBlock"><Setter Property="Foreground" Value="{StaticResource TextGreen}"/></Style>
                                </ContentPresenter.Resources>
                            </ContentPresenter>
                            <Popup Name="Popup" Placement="Bottom" IsOpen="{TemplateBinding IsDropDownOpen}" AllowsTransparency="True" Focusable="False" PopupAnimation="Slide">
                                <Border Background="#1A202C" BorderThickness="1" BorderBrush="#3A3F44" MinWidth="{TemplateBinding ActualWidth}" MaxHeight="150">
                                    <ScrollViewer Margin="0,2" SnapsToDevicePixels="True">
                                        <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained"/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="{StaticResource TextMain}"/>
            <Setter Property="Padding" Value="4,2"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="#4A5568"/></Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>
    <Canvas>
        <Border Canvas.Left="12" Canvas.Top="12" Width="500" Height="476"
                Background="{StaticResource BgPanel}" CornerRadius="8"
                BorderBrush="{StaticResource BorderMain}" BorderThickness="1">
            <Grid>
                <Canvas>
                    <TextBlock Text="EXPERT TORRC CONFIGURATION" Canvas.Left="15" Canvas.Top="12"
                               FontSize="10" Foreground="{StaticResource TextMuted}" FontWeight="Bold"/>
                    <TextBlock Text="Hardware Accel:" Canvas.Left="15" Canvas.Top="35" FontSize="11" Foreground="{StaticResource TextMuted}"/>
                    <ComboBox Name="cmbHW" Canvas.Left="15" Canvas.Top="53" Width="140" Height="26" FontSize="11" Style="{StaticResource DarkComboBox}">
                        <ComboBoxItem Content="Disabled"/><ComboBoxItem Content="Enabled"/>
                    </ComboBox>
                    <TextBlock Text="Fascist Firewall:" Canvas.Left="175" Canvas.Top="35" FontSize="11" Foreground="{StaticResource TextMuted}"/>
                    <ComboBox Name="cmbFF" Canvas.Left="175" Canvas.Top="53" Width="140" Height="26" FontSize="11" Style="{StaticResource DarkComboBox}">
                        <ComboBoxItem Content="Disabled"/><ComboBoxItem Content="Enabled"/>
                    </ComboBox>
                    <TextBlock Text="Strict Nodes:" Canvas.Left="335" Canvas.Top="35" FontSize="11" Foreground="{StaticResource TextMuted}"/>
                    <ComboBox Name="cmbSN" Canvas.Left="335" Canvas.Top="53" Width="150" Height="26" FontSize="11" Style="{StaticResource DarkComboBox}">
                        <ComboBoxItem Content="Disabled"/><ComboBoxItem Content="Enabled"/>
                    </ComboBox>
                    <TextBlock Text="CircuitBuildTimeout:" Canvas.Left="15" Canvas.Top="90" FontSize="11" Foreground="{StaticResource TextMuted}"/>
                    <TextBox Name="txtCBT" Canvas.Left="15" Canvas.Top="108" Width="140" Height="26" Background="{StaticResource BgInput}" Foreground="{StaticResource TextGreen}" BorderBrush="{StaticResource BorderMain}" BorderThickness="1" Padding="4" FontSize="12" FontFamily="Consolas" VerticalContentAlignment="Center"/>
                    <TextBlock Text="KeepalivePeriod:" Canvas.Left="175" Canvas.Top="90" FontSize="11" Foreground="{StaticResource TextMuted}"/>
                    <TextBox Name="txtKP" Canvas.Left="175" Canvas.Top="108" Width="140" Height="26" Background="{StaticResource BgInput}" Foreground="{StaticResource TextGreen}" BorderBrush="{StaticResource BorderMain}" BorderThickness="1" Padding="4" FontSize="12" FontFamily="Consolas" VerticalContentAlignment="Center"/>
                    <TextBlock Text="NewCircuitPeriod:" Canvas.Left="335" Canvas.Top="90" FontSize="11" Foreground="{StaticResource TextMuted}"/>
                    <TextBox Name="txtNCP" Canvas.Left="335" Canvas.Top="108" Width="150" Height="26" Background="{StaticResource BgInput}" Foreground="{StaticResource TextGreen}" BorderBrush="{StaticResource BorderMain}" BorderThickness="1" Padding="4" FontSize="12" FontFamily="Consolas" VerticalContentAlignment="Center"/>
                    <TextBlock Text="MaxCircuitDirtiness:" Canvas.Left="15" Canvas.Top="145" FontSize="11" Foreground="{StaticResource TextMuted}"/>
                    <TextBox Name="txtMCD" Canvas.Left="15" Canvas.Top="163" Width="140" Height="26" Background="{StaticResource BgInput}" Foreground="{StaticResource TextGreen}" BorderBrush="{StaticResource BorderMain}" BorderThickness="1" Padding="4" FontSize="12" FontFamily="Consolas" VerticalContentAlignment="Center"/>
                    <TextBlock Text="NumEntryGuards:" Canvas.Left="175" Canvas.Top="145" FontSize="11" Foreground="{StaticResource TextMuted}"/>
                    <TextBox Name="txtNEG" Canvas.Left="175" Canvas.Top="163" Width="140" Height="26" Background="{StaticResource BgInput}" Foreground="{StaticResource TextGreen}" BorderBrush="{StaticResource BorderMain}" BorderThickness="1" Padding="4" FontSize="12" FontFamily="Consolas" VerticalContentAlignment="Center"/>
                    <TextBlock Text="EntryNodes (e.g., {us}):" Canvas.Left="15" Canvas.Top="200" FontSize="11" Foreground="{StaticResource TextMuted}"/>
                    <TextBox Name="txtEN" Canvas.Left="15" Canvas.Top="218" Width="225" Height="26" Background="{StaticResource BgInput}" Foreground="{StaticResource TextGreen}" BorderBrush="{StaticResource BorderMain}" BorderThickness="1" Padding="4" FontSize="12" FontFamily="Consolas" VerticalContentAlignment="Center"/>
                    <TextBlock Text="ExitNodes (e.g., {uk},{de}):" Canvas.Left="260" Canvas.Top="200" FontSize="11" Foreground="{StaticResource TextMuted}"/>
                    <TextBox Name="txtExit" Canvas.Left="260" Canvas.Top="218" Width="225" Height="26" Background="{StaticResource BgInput}" Foreground="{StaticResource TextGreen}" BorderBrush="{StaticResource BorderMain}" BorderThickness="1" Padding="4" FontSize="12" FontFamily="Consolas" VerticalContentAlignment="Center"/>
                    <TextBlock Text="ExcludeNodes:" Canvas.Left="15" Canvas.Top="255" FontSize="11" Foreground="{StaticResource TextMuted}"/>
                    <TextBox Name="txtExNodes" Canvas.Left="15" Canvas.Top="273" Width="225" Height="26" Background="{StaticResource BgInput}" Foreground="{StaticResource TextGreen}" BorderBrush="{StaticResource BorderMain}" BorderThickness="1" Padding="4" FontSize="12" FontFamily="Consolas" VerticalContentAlignment="Center"/>
                    <TextBlock Text="ExcludeExitNodes:" Canvas.Left="260" Canvas.Top="255" FontSize="11" Foreground="{StaticResource TextMuted}"/>
                    <TextBox Name="txtExExit" Canvas.Left="260" Canvas.Top="273" Width="225" Height="26" Background="{StaticResource BgInput}" Foreground="{StaticResource TextGreen}" BorderBrush="{StaticResource BorderMain}" BorderThickness="1" Padding="4" FontSize="12" FontFamily="Consolas" VerticalContentAlignment="Center"/>
                    <TextBlock Text="Custom Torrc Lines (Advanced - One per line):" Canvas.Left="15" Canvas.Top="310" FontSize="11" Foreground="{StaticResource TextMuted}"/>
                    <TextBox Name="txtRaw" Canvas.Left="15" Canvas.Top="328" Width="470" Height="80" Background="{StaticResource BgInput}" Foreground="{StaticResource TextGreen}" BorderBrush="{StaticResource BorderMain}" BorderThickness="1" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" Padding="4" FontSize="12" FontFamily="Consolas"/>
                    <Button Name="btnOk" Content="Save Config" Canvas.Left="265" Canvas.Top="430" Width="110" Height="25" IsDefault="True" Style="{StaticResource SaveButton}"/>
                    <Button Name="btnCancel" Content="Cancel" Canvas.Left="385" Canvas.Top="430" Width="100" Height="25" IsCancel="True"/>
                </Canvas>
                <Button Name="btnCloseDialog" HorizontalAlignment="Right" VerticalAlignment="Top"
                        Margin="0,6,6,0" Width="22" Height="22" Content="&#x2715;"
                        FontSize="10" FontWeight="Bold" Padding="0,-1,0,0">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Foreground" Value="#4A5568"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Cursor" Value="Hand"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="3">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#2D3748"/>
                                    <Setter Property="Foreground" Value="#E2E8F0"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>
        </Border>
    </Canvas>
</Window>
