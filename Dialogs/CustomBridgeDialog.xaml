<Window x:Class="CrimsonOnion.Dialogs.CustomBridgeDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CUSTOM BRIDGE CONFIGURATIONS" Height="260" Width="420"
        WindowStartupLocation="CenterOwner" Background="Transparent" Foreground="#E2E8F0"
        ResizeMode="NoResize" FontFamily="Segoe UI" ShowInTaskbar="False"
        WindowStyle="None" AllowsTransparency="True">
    <Window.Resources>
        <SolidColorBrush x:Key="BgPanel"     Color="#121417"/>
        <SolidColorBrush x:Key="BgInput"     Color="#0A0C0F"/>
        <SolidColorBrush x:Key="BorderMain"  Color="#2D3748"/>
        <SolidColorBrush x:Key="BorderLight" Color="#3A3F44"/>
        <SolidColorBrush x:Key="TextMain"    Color="#E2E8F0"/>
        <SolidColorBrush x:Key="TextMuted"   Color="#A0AEC0"/>
        <SolidColorBrush x:Key="TextGreen"   Color="#68D391"/>
        <SolidColorBrush x:Key="ColorOk"     Color="#4E7A5E"/>
        <SolidColorBrush x:Key="ColorHover"  Color="#5F9774"/>
        <Style TargetType="Button">
            <Setter Property="Background" Value="#3A3F44"/>
            <Setter Property="Foreground" Value="{StaticResource TextMain}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="#4A5568"/></Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="Button" x:Key="SaveButton" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="{StaticResource ColorOk}"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="{StaticResource ColorHover}"/></Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>
    <Canvas>
        <Border Name="borderMain" Canvas.Left="12" Canvas.Top="12" Width="390" Height="206"
                Background="{StaticResource BgPanel}" CornerRadius="8"
                BorderBrush="{StaticResource BorderMain}" BorderThickness="1">
            <Grid>
                <Canvas>
                    <TextBlock Text="CUSTOM BRIDGE CONFIGURATIONS" Canvas.Left="15" Canvas.Top="12"
                               FontSize="10" Foreground="{StaticResource TextMuted}" FontWeight="Bold"/>
                    <TextBox Name="txtInput" Canvas.Left="15" Canvas.Top="35" Width="350" Height="80"
                             Background="{StaticResource BgInput}" Foreground="{StaticResource TextGreen}"
                             BorderBrush="{StaticResource BorderMain}" BorderThickness="1"
                             TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto"
                             Padding="5" FontSize="11" FontFamily="Consolas"/>
                    <Border Name="panGetBridges" Canvas.Left="15" Canvas.Top="125" Width="350" Height="26"
                            BorderBrush="{StaticResource BorderMain}" BorderThickness="1" CornerRadius="4"
                            Background="{StaticResource BgInput}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="116"/>
                                <ColumnDefinition Width="1"/>
                                <ColumnDefinition Width="116"/>
                                <ColumnDefinition Width="1"/>
                                <ColumnDefinition Width="116"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="GET BRIDGES" FontSize="10" FontWeight="Bold"
                                       Foreground="{StaticResource TextMuted}" HorizontalAlignment="Center"
                                       VerticalAlignment="Center" Margin="0,-1,0,0"/>
                            <Rectangle Grid.Column="1" Fill="{StaticResource BorderMain}"/>
                            <Button Name="btnGetWebTunnel" Grid.Column="2" Content="WEBTUNNEL"
                                    FontSize="10" FontWeight="Bold" Foreground="#E2E8F0" BorderThickness="0" Background="Transparent">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="bg" Background="Transparent">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="bg" Property="Background" Value="#25FFFFFF"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                            <Rectangle Grid.Column="3" Fill="{StaticResource BorderMain}"/>
                            <Button Name="btnGetObfs4" Grid.Column="4" Content="OBFS4"
                                    FontSize="10" FontWeight="Bold" Foreground="#E2E8F0" BorderThickness="0" Background="Transparent">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="bg" Background="Transparent">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="bg" Property="Background" Value="#25FFFFFF"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </Grid>
                    </Border>
                    <Border Name="panCaptcha" Canvas.Left="15" Canvas.Top="125" Width="350" Height="85"
                            Background="{StaticResource BgInput}" BorderBrush="{StaticResource BorderMain}"
                            BorderThickness="1" CornerRadius="4" Visibility="Collapsed" Opacity="0">
                        <Canvas>
                            <Image Name="imgCaptcha" Canvas.Left="5" Canvas.Top="5" Width="140" Height="73" Stretch="Uniform"/>
                            <TextBlock Canvas.Left="155" Canvas.Top="10" Text="ENTER CAPTCHA:"
                                       FontSize="10" FontWeight="Bold" Foreground="{StaticResource TextMuted}"/>
                            <TextBox Name="txtCaptchaSol" Canvas.Left="155" Canvas.Top="26" Width="185" Height="24"
                                     Background="{StaticResource BgPanel}" Foreground="{StaticResource TextMain}"
                                     BorderBrush="{StaticResource BorderLight}" BorderThickness="1"
                                     Padding="4" VerticalContentAlignment="Center" FontFamily="Consolas"/>
                            <Button Name="btnCaptchaSubmit" Content="SUBMIT" Canvas.Left="155" Canvas.Top="56"
                                    Width="88" Height="22" FontSize="10" FontWeight="Bold"
                                    Background="{StaticResource ColorOk}" Foreground="#FFF" BorderThickness="0">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="3">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                            <Button Name="btnCaptchaCancel" Content="CANCEL" Canvas.Left="252" Canvas.Top="56"
                                    Width="88" Height="22" FontSize="10" FontWeight="Bold"
                                    Background="#8B4A4A" Foreground="#FFF" BorderThickness="0">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="3">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </Canvas>
                    </Border>
                    <Button Name="btnOk" Content="Save" Canvas.Left="175" Canvas.Top="165"
                            Width="90" Height="25" IsDefault="True" Style="{StaticResource SaveButton}"/>
                    <Button Name="btnCancel" Content="Cancel" Canvas.Left="275" Canvas.Top="165"
                            Width="90" Height="25" IsCancel="True"/>
                </Canvas>
                <Button Name="btnCloseDialog" HorizontalAlignment="Right" VerticalAlignment="Top"
                        Margin="0,6,6,0" Width="22" Height="22" Content="&#x2715;"
                        FontSize="10" FontWeight="Bold" Padding="0,-1,0,0">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Foreground" Value="#4A5568"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Cursor" Value="Hand"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="3">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#2D3748"/>
                                    <Setter Property="Foreground" Value="#E2E8F0"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>
        </Border>
    </Canvas>
</Window>
